<script>
var BIST30=['AKBNK','ARCLK','ASELS','BIMAS','EKGYO','EREGL','FROTO','GARAN','GUBRF','HEKTS','ISCTR','KCHOL','KOZAA','KOZAL','KRDMD','MGROS','ODAS','PETKM','PGSUS','SAHOL','SASA','SISE','TAVHL','TCELL','THYAO','TKFEN','TOASO','TUPRS','VESTL','YKBNK'];
var BIST50=BIST30.concat(['AEFES','AKSA','ALARK','AYGAZ','CCOLA','DOHOL','ENKAI','GESAN','HALKB','ISGYO','KONTR','LOGO','MPARK','NETAS','OTKAR','OYAKC','SARKY','SOKM','TTKOM','VAKBN']);
var BIST100=BIST50.concat(['ADEL','AFYON','AGESA','AKCNS','AKENR','AKFGY','ALGYO','ALKIM','ANHYT','ANSGR','AVISA','AYDEM','BASGZ','BIENY','BRISA','BRYAT','BUCIM','CANTE','CEMTS','CIMSA','DOAS','EGEEN','ENJSA','EUPWR','GENIL','GLYHO','GOZDE','GSDHO','INDES','ISMEN','KARSN','KLSER','KORDS','MAVI','OBAMS','SELEC','SKBNK','SNGYO','TATGD','TMSN','TRGYO','TSKB','TTRAK','TURSG','ULKER','ULUUN','VERUS','YATAS']);
BIST100=[...new Set(BIST100)];
var BISTALL=BIST100.concat(['ACSEL','ADESE','AGROT','AHGAZ','AKMGY','ALBRK','ANGEN','ARENA','ARMDA','ARZUM','ASTOR','ATAGY','ATEKS','ATLAS','AVHOL','BAGFS','BAKAB','BALAT','BANVT','BARMA','BERA','BIGCH','BJKAS','BMSTL','BOSSA','BRSAN','BSOKE','BTCIM','BURCE','CASA','CELHA','CLEBI','COSMO','CUSAN','CVKMD','DAGI','DENGE','DERIM','DEVA','DITAS','DMSAS','DOBUR','DYOBY','ECILC','EDIP','EKSUN','EPLAS','ERSU','FADE','FONET','FORMT','FRIGO','GEDIK','GEDZA','GENTS','GIBAS','GOLTS','GOODY','GRSEL','GSRAY','GWIND','HATEK','HUBVC','HUNER','IDEAS','IHLAS','IMASM','IZFAS','IZMDC','JANTS','KAPLM','KFEIN','KGYO','KMPUR','KNFRT','KONYA','KUTPO','KUYAS','LIDER','LILAK','LINK','LUKSK','MACKO','MAGEN','MEGAP','MEPET','MERCN','METUR','MOGAN','MTRKS','NTHOL','NUGYO','NUHCM','OBASE','ORGE','OSMEN','OYLUM','OZBAL','PAMEL','PENGD','PENTA','PETUN','PKART','POLHO','PRDGS','PRKAB','PRZMA','ROYAL','SAFKR','SANEL','SAYAS','SEKUR','SILVR','SMART','SNICA','SODSN','SUWEN','TBORG','TEKTU','TERA','TGSAS','TLMAN','TMPOL','TUCLK','TUKAS','TUREX','UFUK','USAK','VKGYO','YAPRK','YKSLN','ZOREN','ZRGYO']);
BISTALL=[...new Set(BISTALL)];

function getStockList(){var s=document.getElementById('scanListSel').value;if(s==='bist30')return BIST30.slice();if(s==='bist50')return BIST50.slice();if(s==='bist100')return BIST100.slice();return BISTALL.slice()}

var G_data=null,G_ind=null,G_sig=null,scanResults=[],scanRunning=false,scanFilter='all',scanSortKey='score',scanSortDir=-1,expandedRow=null;

setInterval(function(){var now=new Date();document.getElementById('clock').textContent=now.toLocaleTimeString('tr-TR');var h=now.getHours(),d=now.getDay();var open=d>=1&&d<=5&&h>=10&&h<18;var el=document.getElementById('mktStatus');el.textContent=open?'Piyasa Açık':'Piyasa Kapalı';el.style.color=open?'var(--green)':'var(--t3)'},1000);

function switchTab(name){var tabs=['analyze','scanner','trades','portfolio'];document.querySelectorAll('.tab').forEach(function(t,i){t.classList.toggle('active',tabs[i]===name)});document.querySelectorAll('.tab-content').forEach(function(t){t.classList.remove('active')});document.getElementById('tab-'+name).classList.add('active')}
document.querySelectorAll('.qs').forEach(function(el){el.onclick=function(){document.getElementById('symInp').value=el.dataset.c}});
document.getElementById('symInp').addEventListener('keypress',function(e){if(e.key==='Enter')doAnalyze()});
document.getElementById('apiKey').addEventListener('input',function(){var d=document.getElementById('apiDot'),t=document.getElementById('apiTxt');if(this.value.trim().indexOf('sk-ant-')===0){d.className='api-dot on';t.textContent='Claude Opus 4.6 aktif (standalone)';t.style.color='var(--purple)';var apb=document.getElementById('aiPicksBtn');if(apb&&scanResults.length>0)apb.style.display='inline-block'}else{d.className='api-dot off';t.textContent='Claude.ai\'da otomatik · Standalone için key girin';t.style.color='var(--t3)'}});

function log(msg,cls){var box=document.getElementById('logBox'),div=document.createElement('div');div.className=cls||'';div.textContent='['+new Date().toLocaleTimeString('tr-TR')+'] '+msg;box.appendChild(div);box.scrollTop=box.scrollHeight}
function setBadge(t,c){var b=document.getElementById('badge');b.textContent=t;b.className='badge '+c}
function showDataStatus(msg,ok){var el=document.getElementById('dSource');if(el)el.textContent=msg;if(!ok){var el2=document.getElementById('logBox');if(el2){var d=document.createElement('div');d.className='warn';d.textContent='['+new Date().toLocaleTimeString('tr-TR')+'] '+msg;el2.appendChild(d)}}}
function getApiKey(){var raw=document.getElementById('apiKey').value;var clean='';for(var i=0;i<raw.length;i++){var code=raw.charCodeAt(i);if(code>=32&&code<=126)clean+=raw.charAt(i)}return clean}
function hasApiKey(){return getApiKey().indexOf('sk-ant-')===0}


// ====== FETCH ENGINE v4 — MAX RELIABILITY ======
var _cache = {};
var _proxyStats = {total:0, ok:0};

function quickFetch(url, ms) {
  ms = ms || 10000;
  return new Promise(function(res, rej) {
    var done = false;
    var t = setTimeout(function(){if(!done){done=true;rej(new Error('T'))}}, ms);
    fetch(url).then(function(r){if(!done){done=true;clearTimeout(t);res(r)}})
    .catch(function(e){if(!done){done=true;clearTimeout(t);rej(e)}});
  });
}

async function tryProxy(url, ms) {
  try {
    var r = await quickFetch(url, ms || 10000);
    if (!r.ok) return null;
    var ct = r.headers.get('content-type') || '';
    if (ct.indexOf('json') >= 0) {
      var j = await r.json();
      // allorigins wrapper
      if (j && j.contents && j.contents.length > 50) return j.contents;
      // direct JSON
      if (j && (j.chart || j.length > 5)) return JSON.stringify(j);
      return null;
    }
    var t = await r.text();
    return (t && t.length > 50) ? t : null;
  } catch(e) { return null; }
}

// Race 4 proxies — first success wins
function getData(targetUrl, ms) {
  ms = ms || 10000;
  _proxyStats.total++;
  return new Promise(function(resolve) {
    var settled = false;
    var pending = 4;
    function done(text) {
      if (!settled && text) { settled = true; _proxyStats.ok++; resolve(text); }
      else { pending--; if (pending <= 0 && !settled) { settled = true; resolve(null); } }
    }
    // 1. AllOrigins /get (JSON wrapper)
    tryProxy('https://api.allorigins.win/get?url=' + encodeURIComponent(targetUrl), ms).then(done);
    // 2. corsproxy.io
    tryProxy('https://corsproxy.io/?' + encodeURIComponent(targetUrl), ms).then(done);
    // 3. AllOrigins /raw
    tryProxy('https://api.allorigins.win/raw?url=' + encodeURIComponent(targetUrl), ms).then(done);
    // 4. corsproxy.org (backup)
    tryProxy('https://corsproxy.org/?' + encodeURIComponent(targetUrl), ms).then(done);
    setTimeout(function() { if (!settled) { settled = true; resolve(null); } }, ms + 2000);
  });
}

function parseYahoo(text) {
  try {
    var data = typeof text === 'string' ? JSON.parse(text) : text;
    var r = data && data.chart && data.chart.result && data.chart.result[0];
    if (!r || !r.timestamp || r.timestamp.length < 5) return null;
    var ts = r.timestamp, q = r.indicators.quote[0], prices = [];
    for (var i = 0; i < ts.length; i++) {
      if (q.close[i] == null || q.close[i] <= 0) continue;
      prices.push({date:new Date(ts[i]*1000), open:q.open[i]!=null?q.open[i]:q.close[i], high:q.high[i]!=null?q.high[i]:q.close[i], low:q.low[i]!=null?q.low[i]:q.close[i], close:q.close[i], volume:q.volume[i]||0});
    }
    return prices.length >= 10 ? prices : null;
  } catch(e) { return null; }
}

function parseForeks(text) {
  try {
    var data = typeof text === 'string' ? JSON.parse(text) : text;
    if (!data || !data.length || data.length < 10) return null;
    var prices = [];
    for (var i = 0; i < data.length; i++) {
      var d = data[i]; if (!d.c || d.c <= 0) continue;
      prices.push({date:new Date(d.d), open:d.o||d.c, high:d.h||d.c, low:d.l||d.c, close:d.c, volume:d.v||0});
    }
    return prices.length >= 10 ? prices : null;
  } catch(e) { return null; }
}

async function fetchSingle(symbol, range, interval, scanMode) {
  if (interval === '1h') interval = '60m';
  if (interval === '30m' || interval === '60m') {
    if (range === '1y' || range === '2y') range = '6mo';
    if (interval === '30m' && range === '6mo') range = '3mo';
  }
  var ck = symbol + '_' + range + '_' + interval;
  var c = _cache[ck];
  if (c && (Date.now() - c._ts < 1800000)) return c;

  var ms = scanMode ? 10000 : 12000;

  // Yahoo v8
  var url8 = 'https://query1.finance.yahoo.com/v8/finance/chart/' + symbol + '.IS?range=' + range + '&interval=' + interval + '&includePrePost=false';
  var text = await getData(url8, ms);
  if (text) { var p = parseYahoo(text); if (p) { var r = {symbol:symbol,prices:p,source:'Yahoo',_ts:Date.now()}; _cache[ck]=r; return r; } }

  // Yahoo v7
  var url7 = 'https://query2.finance.yahoo.com/v7/finance/chart/' + symbol + '.IS?range=' + range + '&interval=' + interval;
  text = await getData(url7, ms);
  if (text) { var p = parseYahoo(text); if (p) { var r = {symbol:symbol,prices:p,source:'Y7',_ts:Date.now()}; _cache[ck]=r; return r; } }

  // Foreks (daily only)
  if (interval === '1d' || interval === '1wk') {
    var last = range==='5d'?5:range==='1mo'?22:range==='3mo'?66:range==='6mo'?132:252;
    var fUrl = 'https://web-paragaranti-pubsub.foreks.com/web-services/historical-data?userName=undefined&name='+symbol+'&exchange=BIST&market=N&group=E&last='+last+'&period=1440&intraPeriod=null&isLast=false';
    try { var r = await quickFetch(fUrl, 8000); if(r.ok){text=await r.text();var p=parseForeks(text);if(p){var res={symbol:symbol,prices:p,source:'Foreks',_ts:Date.now()};_cache[ck]=res;return res;}}} catch(e){}
    text = await getData(fUrl, 10000);
    if(text){var p=parseForeks(text);if(p){var res={symbol:symbol,prices:p,source:'Foreks/P',_ts:Date.now()};_cache[ck]=res;return res;}}
  }

  return null;
}

async function fetchData(symbol, range, interval) {
  log(symbol + '.IS cekiliyor...', 'info');
  var ck = symbol + '_' + range + '_' + (interval==='1h'?'60m':interval);
  // Try 1
  var d = await fetchSingle(symbol, range, interval, false);
  if (d) { log(d.prices.length + ' bar (' + d.source + ')', 'ok'); return d; }
  // Try 2: wait + clear cache
  log('Tekrar deneniyor (2/3)...', 'warn');
  delete _cache[ck];
  await new Promise(function(r){setTimeout(r,2000)});
  d = await fetchSingle(symbol, range, interval, false);
  if (d) { log(d.prices.length + ' bar (R2/' + d.source + ')', 'ok'); return d; }
  // Try 3: different range
  var alt = range==='6mo'?'1y':range==='3mo'?'6mo':range==='1mo'?'3mo':range;
  if (alt !== range) {
    log('Farkli aralik deneniyor ('+alt+')...', 'warn');
    d = await fetchSingle(symbol, alt, interval, false);
    if (d) { log(d.prices.length + ' bar (R3/' + d.source + ')', 'ok'); return d; }
  }
  log(symbol + ' alinamadi — Demo veriyi deneyin', 'err');
  return null;
}

// Generate realistic demo data for any stock
function generateDemoData(symbol, days) {
  days = days || 180;
  var base = 50 + Math.random() * 200;
  var prices = [];
  var vol = base * 0.02;
  var trend = (Math.random() - 0.45) * 0.002;
  for (var i = 0; i < days; i++) {
    var d = new Date(); d.setDate(d.getDate() - days + i);
    if (d.getDay() === 0 || d.getDay() === 6) continue;
    var chg = (Math.random()-0.5)*vol*2 + trend*base;
    base = Math.max(base*0.7, base + chg);
    var hi = base * (1 + Math.random()*0.02);
    var lo = base * (1 - Math.random()*0.02);
    var op = lo + Math.random()*(hi-lo);
    prices.push({date:d, open:op, high:hi, low:lo, close:base, volume:Math.floor(1000000+Math.random()*5000000)});
  }
  return {symbol:symbol, prices:prices, source:'Demo', _ts:Date.now()};
}

// Fetch fundamentals
async function fetchFundamentals(symbol) {
  var url = 'https://query1.finance.yahoo.com/v10/finance/quoteSummary/' + symbol + '.IS?modules=defaultKeyStatistics,financialData,summaryDetail';
  var text = await getData(url, 10000);
  if (!text) return null;
  try {
    var data = JSON.parse(text);
    var result = data.quoteSummary && data.quoteSummary.result && data.quoteSummary.result[0];
    if (!result) return null;
    var stats = result.defaultKeyStatistics || {};
    var fin = result.financialData || {};
    var sum = result.summaryDetail || {};
    return {pe:sum.trailingPE?sum.trailingPE.raw:null, pb:stats.priceToBook?stats.priceToBook.raw:null,
      divYield:sum.dividendYield?(sum.dividendYield.raw*100):null, marketCap:sum.marketCap?sum.marketCap.raw:null,
      roe:fin.returnOnEquity?(fin.returnOnEquity.raw*100):null, debtToEquity:fin.debtToEquity?fin.debtToEquity.raw:null,
      targetPrice:fin.targetMeanPrice?fin.targetMeanPrice.raw:null, recommendation:fin.recommendationKey||null,
      revenueGrowth:fin.revenueGrowth?(fin.revenueGrowth.raw*100):null, profitMargin:fin.profitMargins?(fin.profitMargins.raw*100):null};
  } catch(e) { return null; }
}

// ====== SMART MONEY INDICATORS ======
// Money Flow Index (volume-weighted RSI - shows institutional buying/selling)
function _mfi(prices,p){p=p||14;if(prices.length<p+1)return null;var mfPos=0,mfNeg=0;for(var i=prices.length-p;i<prices.length;i++){var tp=(prices[i].high+prices[i].low+prices[i].close)/3;var prevTp=(prices[i-1].high+prices[i-1].low+prices[i-1].close)/3;var mf=tp*prices[i].volume;if(tp>prevTp)mfPos+=mf;else mfNeg+=mf}if(mfNeg===0)return 100;var ratio=mfPos/mfNeg;return 100-100/(1+ratio)}

// On-Balance Volume (cumulative volume flow - smart money accumulation/distribution)
function _obv(prices){var obv=[0];for(var i=1;i<prices.length;i++){if(prices[i].close>prices[i-1].close)obv.push(obv[i-1]+prices[i].volume);else if(prices[i].close<prices[i-1].close)obv.push(obv[i-1]-prices[i].volume);else obv.push(obv[i-1])}return obv}

// OBV Trend (is OBV rising while price is flat/down = accumulation)
function _obvTrend(obv,closes,lookback){lookback=lookback||20;if(obv.length<lookback)return'neutral';var obvStart=obv[obv.length-lookback],obvEnd=obv[obv.length-1];var priceStart=closes[closes.length-lookback],priceEnd=closes[closes.length-1];var obvChg=(obvEnd-obvStart)/(Math.abs(obvStart)||1);var priceChg=(priceEnd-priceStart)/priceStart;if(obvChg>0.05&&priceChg<0)return'accumulation';if(obvChg<-0.05&&priceChg>0)return'distribution';if(obvChg>0.05&&priceChg>0)return'confirmation';return'neutral'}

// Accumulation/Distribution Line
function _adl(prices){var adl=[0];for(var i=0;i<prices.length;i++){var h=prices[i].high,l=prices[i].low,c=prices[i].close,v=prices[i].volume;var mfm=(h===l)?0:((c-l)-(h-c))/(h-l);adl.push((adl[adl.length-1]||0)+mfm*v)}return adl}

// Volume Weighted Average Price (institutional benchmark)
function _vwap(prices,lookback){lookback=lookback||20;var start=Math.max(0,prices.length-lookback);var cumVol=0,cumTP=0;for(var i=start;i<prices.length;i++){var tp=(prices[i].high+prices[i].low+prices[i].close)/3;cumVol+=prices[i].volume;cumTP+=tp*prices[i].volume}return cumVol>0?cumTP/cumVol:null}

// ====== SETUP PATTERN DETECTION ======
function detectSetups(prices,ind){
  var setups=[];var p=ind.lastClose;var n=prices.length;
  // 1. Bollinger Squeeze Breakout (low vol -> explosion imminent)
  if(ind.lastBU&&ind.lastBL&&ind.lastBM){var bw=(ind.lastBU-ind.lastBL)/ind.lastBM;if(bw<0.04){setups.push({name:'Bollinger Sikisma',desc:'Bantlar son derece dar ('+((bw)*100).toFixed(1)+'%). Sert hareket kapida. Yon icin hacim kirilamini bekle.',score:1.5,type:'momentum'})}}
  // 2. Oversold Bounce (RSI<30 + near support + volume uptick)
  if(ind.lastRSI&&ind.lastRSI<32){var nearSup=false;for(var i=0;i<ind.sr.length;i++){if(ind.sr[i].type==='support'&&Math.abs(ind.sr[i].price-p)/p<0.02){nearSup=true;break}}if(nearSup){setups.push({name:'Asiri Satim Sicramasi',desc:'RSI '+ind.lastRSI.toFixed(1)+' + destek seviyesinde. Klasik mean-reversion firsati. Kisa vadeli %3-5 potansiyel.',score:2,type:'reversal'})}}
  // 3. MACD Bullish Divergence (price lower low, MACD higher low)
  if(n>=10){var pLow1=Math.min(prices[n-5].low,prices[n-4].low,prices[n-3].low);var pLow2=Math.min(prices[n-10].low,prices[n-9].low,prices[n-8].low);var mNow=ind.macd.macd[n-1];var mPrev=ind.macd.macd[n-6];if(mNow!=null&&mPrev!=null&&pLow1<pLow2&&mNow>mPrev){setups.push({name:'MACD Yukselis Diverjans',desc:'Fiyat dusuk dip yaparken MACD yukseliyor. Guclu trend donusu sinyali.',score:2,type:'reversal'})}}
  // 4. Volume Breakout (price up + volume 2x+)
  if(ind.changePct>1&&ind.volRatio>2){setups.push({name:'Hacim Kirilimi',desc:'Fiyat +'+ind.changePct.toFixed(1)+'% ile yukselirken hacim '+ind.volRatio.toFixed(1)+'x ortalamada. Kurumsal alis sinyali.',score:1.5,type:'breakout'})}
  // 5. Golden Cross Fresh (MA20 just crossed above MA50 in last 3 bars)
  if(ind.ma20[n-1]>ind.ma50[n-1]&&ind.ma20[n-4]&&ind.ma50[n-4]&&ind.ma20[n-4]<ind.ma50[n-4]){setups.push({name:'Taze Golden Cross',desc:'MA-20 son 3 gunde MA-50 yi yukari kirdi. Orta vadeli yukselis baslangici.',score:2,type:'trend'})}
  // 6. Price reclaiming MA200 (long-term trend change)
  if(ind.lastMA200&&p>ind.lastMA200){var prev5=ind.closes[n-5];if(prev5&&prev5<ind.ma200[n-5]){setups.push({name:'MA-200 Geri Kazanimi',desc:'Fiyat uzun vadeli trendi yukari kirdi. Buyuk fonlar bu seviyeyi izler.',score:2,type:'trend'})}}
  // 7. Double bottom near support
  if(n>=20){var lows=[];for(var i=n-20;i<n;i++)lows.push(prices[i].low);var minLow=Math.min.apply(null,lows);var dips=0;for(var i=0;i<lows.length;i++){if(Math.abs(lows[i]-minLow)/minLow<0.01)dips++}if(dips>=2&&p>minLow*1.01){setups.push({name:'Cift Dip Formasyonu',desc:'Son 20 barda ayni seviyede 2 dip. Guclu destek olusumu, yukselis potansiyeli.',score:1.5,type:'reversal'})}}
  // 8. Bearish Distribution (price up but OBV down)
  var obv=_obv(prices);var obvT=_obvTrend(obv,ind.closes,20);
  if(obvT==='distribution'){setups.push({name:'Dagilim Uyarisi',desc:'Fiyat yukselirken OBV dusuyor. Akilli para cikiyor. Dikkatli ol!',score:-2,type:'warning'})}
  if(obvT==='accumulation'){setups.push({name:'Akilli Para Birikimi',desc:'Fiyat dusuk/yatayken OBV yukseliyor. Kurumsal birikim devam ediyor.',score:2,type:'accumulation'})}
  return setups
}

// ====== POSITION SIZING (Kelly Criterion + Fixed Risk) ======
function calcPosition(accountSize,riskPct,entry,stop){
  riskPct=riskPct||2;
  var riskPerShare=Math.abs(entry-stop);
  if(riskPerShare<=0)return{shares:0,cost:0,maxLoss:0};
  var maxRiskTL=accountSize*(riskPct/100);
  var shares=Math.floor(maxRiskTL/riskPerShare);
  var cost=shares*entry;
  var maxLoss=shares*riskPerShare;
  return{shares:shares,cost:cost,maxLoss:maxLoss,riskPct:riskPct,costPct:(cost/accountSize*100)}
}

// Sector mapping for BIST stocks
var SECTORS={THYAO:'Havayolu',PGSUS:'Havayolu',TAVHL:'Havayolu',ASELS:'Savunma',KCHOL:'Holding',SAHOL:'Holding',DOHOL:'Holding',GLYHO:'Holding',GOZDE:'Holding',GSDHO:'Holding',AKBNK:'Banka',GARAN:'Banka',ISCTR:'Banka',YKBNK:'Banka',HALKB:'Banka',VAKBN:'Banka',SKBNK:'Banka',TSKB:'Banka',ALBRK:'Banka',PETKM:'Petrokimya',TUPRS:'Petrokimya',SASA:'Petrokimya',TOASO:'Otomotiv',FROTO:'Otomotiv',DOAS:'Otomotiv',OTKAR:'Otomotiv',EREGL:'Metal',KRDMD:'Metal',CEMTS:'Metal',SISE:'Cam/Sanayi',ARCLK:'Beyaz Esya',VESTL:'Beyaz Esya',BIMAS:'Perakende',MGROS:'Perakende',SOKM:'Perakende',TCELL:'Telekom',TTKOM:'Telekom',EKGYO:'GYO',ISGYO:'GYO',TRGYO:'GYO',SNGYO:'GYO',GUBRF:'Gubre/Kimya',HEKTS:'Gubre/Kimya',KOZAA:'Madencilik',KOZAL:'Madencilik',ENKAI:'Insaat',TKFEN:'Insaat',GESAN:'Insaat',CCOLA:'Gida',ULKER:'Gida',TATGD:'Gida',AEFES:'Gida',LOGO:'Teknoloji',NETAS:'Teknoloji',INDES:'Teknoloji',MAVI:'Tekstil',BRISA:'Lastik',KORDS:'Lastik',AKSA:'Kimya',ALKIM:'Kimya',ODAS:'Enerji',AKENR:'Enerji',ENJSA:'Enerji',AYDEM:'Enerji',EUPWR:'Enerji',AGESA:'Sigorta',ANHYT:'Sigorta',ANSGR:'Sigorta',TURSG:'Sigorta'};

// ATR - Average True Range
function _atr(prices,p){p=p||14;var trs=[];for(var i=1;i<prices.length;i++){var hi=prices[i].high,lo=prices[i].low,pc=prices[i-1].close;trs.push(Math.max(hi-lo,Math.abs(hi-pc),Math.abs(lo-pc)))}var atr=[];var sum=0;for(var i=0;i<trs.length;i++){sum+=trs[i];if(i>=p-1){if(i===p-1)atr.push(sum/p);else{atr.push((atr[atr.length-1]*(p-1)+trs[i])/p);sum-=trs[i-p+1]}}}return atr.length>0?atr[atr.length-1]:null}

// Fibonacci retracement levels from recent swing
function _fib(prices){var n=prices.length;var lookback=Math.min(60,n);var hi=-Infinity,lo=Infinity,hiIdx=0,loIdx=0;for(var i=n-lookback;i<n;i++){if(prices[i].high>hi){hi=prices[i].high;hiIdx=i}if(prices[i].low<lo){lo=prices[i].low;loIdx=i}}var uptrend=loIdx<hiIdx;var diff=hi-lo;if(diff<=0)return null;var fibs={};if(uptrend){fibs.trend='up';fibs.high=hi;fibs.low=lo;fibs['0.0']=hi;fibs['0.236']=hi-diff*0.236;fibs['0.382']=hi-diff*0.382;fibs['0.5']=hi-diff*0.5;fibs['0.618']=hi-diff*0.618;fibs['1.0']=lo;fibs['1.272']=hi+diff*0.272;fibs['1.618']=hi+diff*0.618}else{fibs.trend='down';fibs.high=hi;fibs.low=lo;fibs['0.0']=lo;fibs['0.236']=lo+diff*0.236;fibs['0.382']=lo+diff*0.382;fibs['0.5']=lo+diff*0.5;fibs['0.618']=lo+diff*0.618;fibs['1.0']=hi;fibs['1.272']=lo-diff*0.272;fibs['1.618']=lo-diff*0.618}return fibs}

// Pivot Points (Standard)
function _pivots(prices){var last=prices[prices.length-1];var h=last.high,l=last.low,c=last.close;var pp=(h+l+c)/3;return{pp:pp,r1:2*pp-l,r2:pp+(h-l),r3:h+2*(pp-l),s1:2*pp-h,s2:pp-(h-l),s3:l-2*(h-pp)}}

function genSignal(ind,prices){
  var score=0,reasons=[],p=ind.lastClose;
  var atr=prices?_atr(prices):null;
  var fibs=prices?_fib(prices):null;
  var pivots=prices?_pivots(prices):null;

  // MA Analysis
  if(ind.lastMA20){if(p>ind.lastMA20){score+=1;reasons.push({t:'Fiyat MA-20 ('+ind.lastMA20.toFixed(2)+') ustunde — Kisa vadeli yukselis trendi',c:'bullish'})}else{score-=1;reasons.push({t:'Fiyat MA-20 ('+ind.lastMA20.toFixed(2)+') altinda — Kisa vadeli dususten',c:'bearish'})}}
  if(ind.lastMA50){if(p>ind.lastMA50){score+=1;reasons.push({t:'Fiyat MA-50 ('+ind.lastMA50.toFixed(2)+') ustunde — Orta vadeli trend pozitif',c:'bullish'})}else{score-=1;reasons.push({t:'Fiyat MA-50 ('+ind.lastMA50.toFixed(2)+') altinda — Orta vadeli baski',c:'bearish'})}}
  if(ind.lastMA20&&ind.lastMA50){if(ind.lastMA20>ind.lastMA50){score+=1;reasons.push({t:'MA-20 > MA-50 — Golden cross bolgesi, momentum yukari',c:'bullish'})}else{score-=1;reasons.push({t:'MA-20 < MA-50 — Death cross bolgesi, momentum asagi',c:'bearish'})}}
  // MA200 trend filter
  if(ind.lastMA200){if(p>ind.lastMA200){score+=0.5;reasons.push({t:'Fiyat MA-200 ustunde — Uzun vadeli boga piyasasi',c:'bullish'})}else{score-=0.5;reasons.push({t:'Fiyat MA-200 altinda — Uzun vadeli ayi piyasasi',c:'bearish'})}}

  // RSI with divergence hint
  if(ind.lastRSI!=null){if(ind.lastRSI<25){score+=2.5;reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Asiri satim, guclu toparlanma potansiyeli',c:'bullish'})}else if(ind.lastRSI<35){score+=1.5;reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Satis baskisi azaliyor, dip olusumu',c:'bullish'})}else if(ind.lastRSI<45){score+=0.5;reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Zayif ama iyilesme egilimi',c:'bullish'})}else if(ind.lastRSI>75){score-=2.5;reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Asiri alim, sert duzeltme riski',c:'bearish'})}else if(ind.lastRSI>65){score-=1;reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Yukari gerilmis, dikkatli ol',c:'neutral'})}else{reasons.push({t:'RSI '+ind.lastRSI.toFixed(1)+' — Notr bolge, yonu bekle',c:'neutral'})}}

  // MACD
  if(ind.lastMACD!=null&&ind.lastMACDSig!=null){if(ind.lastMACD>ind.lastMACDSig){score+=1;reasons.push({t:'MACD sinyal ustunde — Alis momentumu hakim',c:'bullish'})}else{score-=1;reasons.push({t:'MACD sinyal altinda — Satis momentumu hakim',c:'bearish'})}var ph2=ind.macd.histogram[ind.macd.histogram.length-2];if(ind.lastMACDHist>0&&ph2!=null&&ind.lastMACDHist>ph2){score+=0.5;reasons.push({t:'Histogram artiyor — Momentum gucleniyor',c:'bullish'})}if(ind.lastMACDHist<0&&ph2!=null&&ind.lastMACDHist>ph2){score+=0.5;reasons.push({t:'Histogram daraliyor — Satis baskisi zayifliyor',c:'bullish'})}}

  // Bollinger with squeeze detection
  if(ind.lastBL&&ind.lastBU){var bbWidth=(ind.lastBU-ind.lastBL)/ind.lastBM;if(bbWidth<0.05){score+=0.5;reasons.push({t:'Bollinger sikisma — Sert hareket bekleniyor',c:'neutral'})}if(p<=ind.lastBL*1.01){score+=1.5;reasons.push({t:'Bollinger alt bandinda — Teknik sicrama bolgesi',c:'bullish'})}else if(p>=ind.lastBU*0.99){score-=1.5;reasons.push({t:'Bollinger ust bandinda — Geri cekilme bolgesi',c:'bearish'})}}

  // Volume confirmation
  if(ind.volRatio>2){score+=1;reasons.push({t:'Hacim '+ind.volRatio.toFixed(1)+'x — Cok guclu kurumsal ilgi',c:'bullish'})}else if(ind.volRatio>1.3){score+=0.5;reasons.push({t:'Hacim '+ind.volRatio.toFixed(1)+'x — Ortalamanin ustunde',c:'bullish'})}else if(ind.volRatio<0.5){score-=0.3;reasons.push({t:'Hacim dusuk — Zayif katilim, sinyal guvenilirligi azalir',c:'neutral'})}

  // Smart Money Analysis
  if(ind.mfi!=null){if(ind.mfi<20){score+=1.5;reasons.push({t:'MFI '+ind.mfi.toFixed(0)+' — Kurumsal asiri satim, akilli para birikiyor',c:'bullish'})}else if(ind.mfi>80){score-=1.5;reasons.push({t:'MFI '+ind.mfi.toFixed(0)+' — Kurumsal asiri alim, kar realizasyonu yakin',c:'bearish'})}else if(ind.mfi<35){score+=0.5;reasons.push({t:'MFI '+ind.mfi.toFixed(0)+' — Dusuk para akisi, birikim bolgesi',c:'bullish'})}}
  if(ind.obvTrend==='accumulation'){score+=1.5;reasons.push({t:'OBV Birikim — Fiyat dusukken hacim akisi yukari, akilli para aliyor',c:'bullish'})}
  else if(ind.obvTrend==='distribution'){score-=1.5;reasons.push({t:'OBV Dagilim — Fiyat yukselirken hacim cikiyor, akilli para satiyor',c:'bearish'})}
  else if(ind.obvTrend==='confirmation'){score+=0.5;reasons.push({t:'OBV Teyit — Hacim akisi fiyat yonunu destekliyor',c:'bullish'})}
  if(ind.vwap&&p>ind.vwap){score+=0.3;reasons.push({t:'VWAP ('+ind.vwap.toFixed(2)+') ustunde — Kurumsal alim bolgesi',c:'bullish'})}
  else if(ind.vwap&&p<ind.vwap){score-=0.3;reasons.push({t:'VWAP ('+ind.vwap.toFixed(2)+') altinda — Kurumsal satis baskisi',c:'bearish'})}

  // Setup detection
  var setups=prices?detectSetups(prices,ind):[];
  for(var si=0;si<setups.length;si++){score+=setups[si].score;reasons.push({t:'SETUP: '+setups[si].name+' — '+setups[si].desc,c:setups[si].score>0?'bullish':setups[si].score<0?'bearish':'neutral'})}

  // Pivot point context
  if(pivots){if(p>pivots.pp&&p<pivots.r1){reasons.push({t:'Pivot ('+pivots.pp.toFixed(2)+') ustunde, R1 ('+pivots.r1.toFixed(2)+') hedefliyor',c:'bullish'})}else if(p<pivots.pp&&p>pivots.s1){reasons.push({t:'Pivot ('+pivots.pp.toFixed(2)+') altinda, S1 ('+pivots.s1.toFixed(2)+') destek',c:'bearish'})}}

  // Signal classification
  var signal,cls;var conf=Math.min(Math.abs(score)/7*100,95);
  if(score>=2.5){signal='GUCLU AL';cls='buy'}else if(score>=1.5){signal='AL';cls='buy'}else if(score<=-2.5){signal='GUCLU SAT';cls='sell'}else if(score<=-1.5){signal='SAT';cls='sell'}else{signal='TUT';cls='hold'}

  // ====== SMART ENTRY / STOP / TARGET ======
  var sup=null,res=null;
  for(var i=0;i<ind.sr.length;i++){var s=ind.sr[i];if(s.type==='support'&&s.price<p&&(!sup||s.price>sup.price))sup=s;if(s.type==='resistance'&&s.price>p&&(!res||s.price<res.price))res=s}

  // ATR-based stop (1.5x ATR below entry)
  var atrStop=atr?(p-1.5*atr):null;
  // Support-based stop (just below nearest support)
  var srStop=sup?sup.price*0.995:null;
  // Use the tighter (higher) of the two as stop
  var stop;
  if(atrStop&&srStop)stop=Math.max(atrStop,srStop);
  else if(srStop)stop=srStop;
  else if(atrStop)stop=atrStop;
  else stop=p*0.95;
  // Don't let stop be more than 8% away
  if(stop<p*0.92)stop=p*0.92;

  // Entry: for AL signals, entry at current; for TUT, wait for pullback to MA20 or support
  var entry=p;
  if(cls==='hold'&&ind.lastMA20&&ind.lastMA20<p){entry=ind.lastMA20}
  else if(cls==='hold'&&sup){entry=sup.price*1.005}

  // Targets using Fibonacci extensions and resistance
  var t1,t2,t3;
  if(res)t1=res.price;
  else if(atr)t1=p+2*atr;
  else t1=p*1.05;

  if(fibs&&fibs.trend==='up'){t2=fibs['1.272']||t1*1.03;t3=fibs['1.618']||t1*1.06}
  else if(pivots){t2=pivots.r2||t1*1.03;t3=pivots.r3||t1*1.06}
  else{t2=t1*1.03;t3=t1*1.06}

  // Make sure targets are above entry
  if(t1<=entry)t1=entry*1.03;
  if(t2<=t1)t2=t1*1.03;
  if(t3<=t2)t3=t2*1.03;

  var risk=entry-stop;var reward=t1-entry;var rr=risk>0?(reward/risk):0;
  var reward2=t2-entry;var rr2=risk>0?(reward2/risk):0;

  // === HOLD DURATION ESTIMATE ===
  // Based on ATR vs distance to target - how many bars to reach target
  var holdBars=null;var holdText='';
  if(atr&&atr>0){
    var barsToT1=Math.ceil((t1-p)/atr);
    if(barsToT1<0)barsToT1=Math.abs(barsToT1);
    holdBars=Math.max(1,barsToT1);
    if(holdBars<=1)holdText='Intraday (gun ici)';
    else if(holdBars<=3)holdText='1-3 gun (kisa vade)';
    else if(holdBars<=10)holdText='1-2 hafta (kisa-orta)';
    else if(holdBars<=25)holdText='2-5 hafta (orta vade)';
    else holdText='1-3 ay (uzun vade)';
  }

  // === INTRADAY METRICS ===
  var dailyRange=0;var avgDailyPct=0;
  if(prices&&prices.length>=5){
    var ranges=[];for(var di=Math.max(0,prices.length-10);di<prices.length;di++){
      var dr=(prices[di].high-prices[di].low)/prices[di].close*100;ranges.push(dr)
    }
    avgDailyPct=ranges.reduce(function(a,b){return a+b},0)/ranges.length;
    dailyRange=avgDailyPct;
  }
  // Intraday target: realistic same-day move based on avg daily range
  var intradayTarget=p*(1+avgDailyPct*0.4/100); // 40% of avg daily range as target
  var intradayStop=p*(1-avgDailyPct*0.25/100);  // 25% of avg daily range as stop
  var intradayRR=((intradayTarget-p)/(p-intradayStop));

  return{signal:signal,cls:cls,score:score,conf:conf.toFixed(0),reasons:reasons,
    stop:stop,t1:t1,t2:t2,t3:t3,rr:rr,rr2:rr2,entry:entry,
    atr:atr,fibs:fibs,pivots:pivots,
    holdBars:holdBars,holdText:holdText,
    dailyRange:dailyRange,intradayTarget:intradayTarget,intradayStop:intradayStop,intradayRR:intradayRR,
    ma20pct:ind.lastMA20?((p-ind.lastMA20)/ind.lastMA20*100):null,
    ma50pct:ind.lastMA50?((p-ind.lastMA50)/ind.lastMA50*100):null,
    bollPct:ind.lastBU&&ind.lastBL?((p-ind.lastBL)/(ind.lastBU-ind.lastBL)*100):null}
}

// ====== CLAUDE AI ENGINE ======
async function callClaude(prompt, useSearch){
  var body = {model:'claude-sonnet-4-20250514',max_tokens:2048,messages:[{role:'user',content:prompt}]};
  if(useSearch)body.tools=[{type:'web_search_20250305',name:'web_search'}];
  var payload = JSON.stringify(body);

  // Attempt 1: artifact mode (no API key needed on claude.ai)
  try{
    var resp = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'}, body:payload
    });
    if(resp.ok){var r=await resp.json();var t=extractClaudeText(r);if(t)return t}
  }catch(e){}

  // Attempt 2: user-provided API key (for standalone use)
  var key=getApiKey();
  if(!key)return null;
  try{
    var h=new Headers();
    h.set('Content-Type','application/json');
    h.set('x-api-key',key);
    h.set('anthropic-version','2023-06-01');
    h.set('anthropic-dangerous-direct-browser-access','true');
    var resp = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:h, body:payload
    });
    var result=await resp.json();
    if(resp.ok)return extractClaudeText(result);
    return 'API Hatasi ('+resp.status+'): '+(result.error?result.error.message:'Bilinmeyen hata');
  }catch(e){return 'Baglanti hatasi: '+e.message}
}
function extractClaudeText(r){if(!r||!r.content)return null;var t='';for(var i=0;i<r.content.length;i++){if(r.content[i].type==='text')t+=r.content[i].text}return t||null}

// Wall Street Expert Prompt for Single Stock
function buildExpertPrompt(symbol,ind,sig){
  return 'Sen Claude Opus 4.6\'sın ve bir Wall Street kıdemli finans uzmanısın. 20+ yıl Goldman Sachs, JP Morgan ve hedge fund deneyimin var. BIST\'te derin uzmanlığın var.\n\n'+
  'GÖREV: '+symbol+' hissesini analiz et. Önce bu şirketle ilgili SON HABERLERİ ve GELİŞMELERİ araştır, sonra teknik verilerle birleştirip kapsamlı bir değerlendirme yap.\n\n'+
  '--- TEKNİK VERİLER ---\n'+
  'HİSSE: '+symbol+'.IS\n'+
  'SON FİYAT: '+ind.lastClose.toFixed(2)+' TL\n'+
  'DEĞİŞİM: '+(ind.changePct>=0?'+':'')+ind.changePct.toFixed(2)+'%\n'+
  'MA-20: '+(ind.lastMA20?ind.lastMA20.toFixed(2):'N/A')+' TL (fiyat '+(ind.lastMA20?(ind.lastClose>ind.lastMA20?'üstünde':'altında'):'?')+')\n'+
  'MA-50: '+(ind.lastMA50?ind.lastMA50.toFixed(2):'N/A')+' TL (fiyat '+(ind.lastMA50?(ind.lastClose>ind.lastMA50?'üstünde':'altında'):'?')+')\n'+
  'RSI(14): '+(ind.lastRSI?ind.lastRSI.toFixed(1):'N/A')+'\n'+
  'MACD: '+(ind.lastMACD!=null?ind.lastMACD.toFixed(3):'N/A')+' / Sinyal: '+(ind.lastMACDSig!=null?ind.lastMACDSig.toFixed(3):'N/A')+'\n'+
  'Bollinger: Alt='+(ind.lastBL?ind.lastBL.toFixed(2):'—')+' Orta='+(ind.lastBM?ind.lastBM.toFixed(2):'—')+' Üst='+(ind.lastBU?ind.lastBU.toFixed(2):'—')+'\n'+
  'Hacim Oranı: '+(ind.volRatio?ind.volRatio.toFixed(1)+'x':'—')+'\n'+
  'AKILLI PARA: MFI='+(ind.mfi!=null?ind.mfi.toFixed(0):'N/A')+' | OBV='+ind.obvTrend+' | VWAP='+(ind.vwap?ind.vwap.toFixed(2):'N/A')+' | A/D='+(ind.adlTrend||'—')+'\n'+
  'Destek/Direnç: '+ind.sr.slice(0,4).map(function(s){return s.type+': '+s.price.toFixed(2)}).join(' | ')+'\n'+
  'TEKNiK SKOR: '+sig.score.toFixed(1)+' -> '+sig.signal+'\n'+
  'GiRiS: '+sig.entry.toFixed(2)+' | STOP (ATR-bazli): '+sig.stop.toFixed(2)+' | HEDEF1: '+sig.t1.toFixed(2)+' | HEDEF2: '+sig.t2.toFixed(2)+' | HEDEF3: '+sig.t3.toFixed(2)+' | R/O: 1:'+sig.rr.toFixed(1)+'\n'+
  (sig.atr?'ATR(14): '+sig.atr.toFixed(2)+'\n':'')+
  (sig.pivots?'Pivot: PP='+sig.pivots.pp.toFixed(2)+' S1='+sig.pivots.s1.toFixed(2)+' R1='+sig.pivots.r1.toFixed(2)+' R2='+sig.pivots.r2.toFixed(2)+'\n':'')+'\n'+
  'Türkçe yanıt ver. Şu yapıda:\n\n'+
  '📰 SON HABERLER & GELİŞMELER\n'+symbol+' ile ilgili son günlerdeki önemli haberleri, şirket gelişmelerini, sektörel değişimleri özetle. Haberlerin fiyata olası etkisini belirt.\n\n'+
  '📊 UZMAN DEĞERLENDİRMESİ\nBu hisseyi bir Wall Street fund manager gözüyle 2-3 cümleyle değerlendir.\n\n'+
  '🔍 TEKNİK YORUM\nTrend yapısı, momentum, hacim profili, pattern tanıma. Kısa ve öz.\n\n'+
  '🎯 STRATEJİ\nŞu anda girmeli mi yoksa belirli bir seviyeyi beklemeli mi? Hangi fiyatta pozisyon açılmalı?\n\n'+
  '⚠️ RİSK NOTU\nBu pozisyonun en büyük riski ne? Portföyün yüzde kaçını ayırmalı?\n\n'+
  '📌 SONUÇ: [AL / TUT / SAT] + Güven: [Yüksek/Orta/Düşük]\nBir cümlelik net yargı.\n\n'+
  'NOT: Bu yatırım tavsiyesi değildir, piyasa okumasıdır.'
}

// Wall Street Expert Prompt for Daily Picks
function buildDailyPicksPrompt(results){
  var buys=results.filter(function(r){return r.cls==='buy'}).sort(function(a,b){return b.score-a.score});
  var sells=results.filter(function(r){return r.cls==='sell'}).sort(function(a,b){return a.score-b.score});
  var topBuys=buys.slice(0,15);
  var topSells=sells.slice(0,5);

  var stockData='BUGÜNKÜ TARAMA SONUÇLARI ('+results.length+' hisse tarandı)\n\n';
  stockData+='EN GÜÇLÜ AL SİNYALLERİ:\n';
  for(var i=0;i<topBuys.length;i++){var r=topBuys[i];stockData+=(i+1)+'. '+r.symbol+' ('+r.sector+') | Fiyat: '+r.price.toFixed(2)+' | Skor: '+r.score.toFixed(1)+' | RSI: '+(r.rsi?r.rsi.toFixed(1):'—')+' | MFI: '+(r.mfi!=null?r.mfi.toFixed(0):'—')+' | AkilliPara: '+r.obvTrend+' | R/O: 1:'+(r.rr?r.rr.toFixed(1):'—')+' | Degisim: '+(r.change>=0?'+':'')+r.change.toFixed(2)+'% | Giris: '+r.entry.toFixed(2)+' | Stop: '+r.stop.toFixed(2)+' | H1: '+r.target.toFixed(2)+' | H2: '+r.target2.toFixed(2)+(r.target3?' | H3: '+r.target3.toFixed(2):'')+'\n'}
  if(topSells.length>0){stockData+='\nEN GÜÇLÜ SAT SİNYALLERİ:\n';for(var i=0;i<topSells.length;i++){var r=topSells[i];stockData+=(i+1)+'. '+r.symbol+' | Fiyat: '+r.price.toFixed(2)+' | Skor: '+r.score.toFixed(1)+' | RSI: '+(r.rsi?r.rsi.toFixed(1):'—')+'\n'}}

  return 'Sen Claude Opus 4.6\'sin ve bir Wall Street kidemli portfoy yoneticisisin. 20+ yil Goldman Sachs ve hedge fund deneyimin var. BIST\'te kurumsal duzey analiz yapiyorsun.\n\n'+
  'Bugunku BIST tarama sonuclari asagida. AKILLI PARA gostergelerini (MFI, OBV trend) ozellikle dikkate al — kurumsal alis/satis baskisini gosterir.\n\n'+
  stockData+'\n\n'+
  'GOREV: Bugunku en iyi 5 ALIM firsatini sec. Ozellikle su kriterlere once ver:\n'+
  '1. Akilli para birikimi gosteren (OBV=accumulation) hisselere oncelik\n'+
  '2. MFI dusuk (kurumsal asiri satim) olanlara oncelik\n'+
  '3. Risk/Odul orani 1:2 uzerinde olanlara oncelik\n'+
  '4. Farkli sektorlerden sec (konsantrasyon riski azalt)\n\n'+
  'Her hisse icin:\n'+
  '🏆 GÜNÜN TOP 5 ALIM FIRSATI\n\n'+
  'Her hisse için:\n'+
  '━━━━━━━━━━━━━━━━━━━━━━\n'+
  '#[SIRA] [HİSSE KODU] — [1 cümle özet]\n'+
  '• Neden şimdi: [teknik sebep]\n'+
  '• Giriş: [fiyat] TL\n'+
  '• Stop-Loss: [fiyat] TL (risk: %X)\n'+
  '• Hedef 1: [fiyat] TL (+%X)\n'+
  '• Hedef 2: [fiyat] TL (+%X)\n'+
  '• Risk/Ödül: 1:X\n'+
  '• Pozisyon Ağırlığı: Portföyün %X\'i\n'+
  '• Beklenen süre: [kısa/orta vade]\n\n'+
  'Sonunda:\n'+
  '📋 PORTFÖY NOTU: Bu 5 hissenin sektör dağılımı, toplam risk profili ve genel piyasa ortamına uyumu hakkında 2-3 cümle.\n\n'+
  '⚠️ KAÇINILACAKLAR: Taramada gördüğün en tehlikeli 2-3 hisse ve neden kaçınılması gerektiği.\n\n'+
  'Gercek bir hedge fund morning meeting\'deki gibi dusun. Net, somut, eyleme gecirilebilir.\n'+
  'Ozellikle AKILLI PARA verilerini yorumla — MFI ve OBV trend\'i kullan.\n'+
  'NOT: Bu yatirim tavsiyesi degildir, teknik piyasa okumasidir.'
}

// ====== CHART ======
function drawChart(prices,ind){var canvas=document.getElementById('mainChart'),ctx=canvas.getContext('2d');canvas.style.display='block';document.getElementById('chartPH').style.display='none';var dpr=window.devicePixelRatio||1,rect=canvas.parentElement.getBoundingClientRect();canvas.width=rect.width*dpr;canvas.height=rect.height*dpr;canvas.style.width=rect.width+'px';canvas.style.height=rect.height+'px';ctx.scale(dpr,dpr);var w=rect.width,h=rect.height,pad={t:18,r:56,b:36,l:8},cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;ctx.clearRect(0,0,w,h);var c=ind.closes,n=c.length;var mn=Infinity,mx=-Infinity;for(var i=0;i<n;i++){if(prices[i].low<mn)mn=prices[i].low;if(prices[i].high>mx)mx=prices[i].high;if(ind.bollinger.upper[i]&&ind.bollinger.upper[i]>mx)mx=ind.bollinger.upper[i];if(ind.bollinger.lower[i]&&ind.bollinger.lower[i]<mn)mn=ind.bollinger.lower[i]}var rng=mx-mn;mn-=rng*.05;mx+=rng*.05;var xS=function(i){return pad.l+(i/(n-1))*cw};var yS=function(p){return pad.t+(1-(p-mn)/(mx-mn))*ch};ctx.strokeStyle='#141e30';ctx.lineWidth=0.5;for(var i=0;i<5;i++){var y=pad.t+(i/4)*ch;ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(w-pad.r,y);ctx.stroke();ctx.fillStyle='#4a5568';ctx.font='9px JetBrains Mono';ctx.textAlign='left';ctx.fillText((mx-(i/4)*(mx-mn)).toFixed(2),w-pad.r+4,y+3)}ctx.beginPath();var started=false;for(var i=0;i<n;i++){if(ind.bollinger.upper[i]==null)continue;if(!started){ctx.moveTo(xS(i),yS(ind.bollinger.upper[i]));started=true}else ctx.lineTo(xS(i),yS(ind.bollinger.upper[i]))}for(var i=n-1;i>=0;i--){if(ind.bollinger.lower[i]==null)continue;ctx.lineTo(xS(i),yS(ind.bollinger.lower[i]))}ctx.closePath();ctx.fillStyle='rgba(41,121,255,.05)';ctx.fill();var drawLine=function(data,col){ctx.beginPath();ctx.strokeStyle=col;ctx.lineWidth=1;var s=false;for(var i=0;i<n;i++){if(data[i]==null)continue;if(!s){ctx.moveTo(xS(i),yS(data[i]));s=true}else ctx.lineTo(xS(i),yS(data[i]))}ctx.stroke()};drawLine(ind.ma20,'#ffd600');drawLine(ind.ma50,'#ff9100');drawLine(ind.ma100,'#d500f9');var cW=Math.max(1,(cw/n)*0.6);for(var i=0;i<n;i++){var x=xS(i),o=prices[i].open,cl=prices[i].close,hi=prices[i].high,lo=prices[i].low;var bull=cl>=o,col=bull?'#00e676':'#ff1744';ctx.strokeStyle=col;ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(x,yS(hi));ctx.lineTo(x,yS(lo));ctx.stroke();ctx.fillStyle=col;var top=yS(Math.max(o,cl)),bot=yS(Math.min(o,cl));ctx.fillRect(x-cW/2,top,cW,Math.max(1,bot-top))}for(var k=0;k<Math.min(4,ind.sr.length);k++){var sr=ind.sr[k];var y=yS(sr.price);if(y<pad.t||y>pad.t+ch)continue;ctx.strokeStyle=sr.type==='support'?'#00e67655':'#ff174455';ctx.lineWidth=1;ctx.setLineDash([4,4]);ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(w-pad.r,y);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle=sr.type==='support'?'#00e676':'#ff1744';ctx.font='8px JetBrains Mono';ctx.textAlign='right';ctx.fillText((sr.type==='support'?'S':'R')+' '+sr.price.toFixed(2),w-pad.r-3,y-3)}ctx.fillStyle='#4a5568';ctx.font='8px JetBrains Mono';ctx.textAlign='center';var step=Math.max(1,Math.floor(n/6));for(var i=0;i<n;i+=step)ctx.fillText(prices[i].date.toLocaleDateString('tr-TR',{day:'2-digit',month:'short'}),xS(i),h-pad.b+16)}

// ====== UI ======
function updateUI(data,ind,sig){
  document.getElementById('chartHdr').style.display='flex';document.getElementById('dName').textContent=data.symbol+'.IS';document.getElementById('dPrice').textContent=ind.lastClose.toFixed(2)+' ₺';var ce=document.getElementById('dChange');ce.textContent=(ind.change>=0?'+':'')+ind.change.toFixed(2)+' ('+(ind.change>=0?'+':'')+ind.changePct.toFixed(2)+'%)';ce.className='sc '+(ind.change>=0?'up':'dn');document.getElementById('dSource').textContent=data.source||'';document.getElementById('indBar').style.display='grid';
  function $(id,v,c){document.getElementById(id).textContent=v;if(c)document.getElementById(id).style.color=c}
  $('iRSI',ind.lastRSI?ind.lastRSI.toFixed(1):'—',ind.lastRSI<30?'var(--green)':ind.lastRSI>70?'var(--red)':'var(--t1)');$('iRSIs',ind.lastRSI<30?'Aşırı Satım':ind.lastRSI>70?'Aşırı Alım':'Nötr');$('iMACD',ind.lastMACD!=null?ind.lastMACD.toFixed(2):'—',ind.lastMACD>0?'var(--green)':'var(--red)');$('iMACDs',ind.lastMACDHist>0?'Pozitif':'Negatif');$('iMA20',ind.lastMA20?ind.lastMA20.toFixed(2):'—',ind.lastClose>(ind.lastMA20||0)?'var(--green)':'var(--red)');$('iMA20s',ind.lastMA20?(ind.lastClose>ind.lastMA20?'Üstünde':'Altında'):'—');$('iMA50',ind.lastMA50?ind.lastMA50.toFixed(2):'—',ind.lastClose>(ind.lastMA50||0)?'var(--green)':'var(--red)');$('iMA50s',ind.lastMA50?(ind.lastClose>ind.lastMA50?'Üstünde':'Altında'):'—');$('iBoll',ind.lastBM?ind.lastBM.toFixed(2):'—');$('iBolls',ind.lastBU&&ind.lastBL?((ind.lastClose-ind.lastBL)/(ind.lastBU-ind.lastBL)*100).toFixed(0)+'%':'—');$('iVol',ind.lastVol?(ind.lastVol/1e6).toFixed(1)+'M':'—');$('iVols',ind.volRatio?ind.volRatio.toFixed(1)+'x':'—');
  $('iMFI',ind.mfi!=null?ind.mfi.toFixed(0):'—',ind.mfi!=null&&ind.mfi<20?'var(--green)':ind.mfi!=null&&ind.mfi>80?'var(--red)':'var(--t1)');$('iMFIs',ind.mfi!=null?(ind.mfi<20?'Kurumsal Alis':ind.mfi>80?'Kar Realizasyonu':'Notr'):'—');
  $('iOBV',ind.obvTrend==='accumulation'?'BIRIKIM':ind.obvTrend==='distribution'?'DAGILIM':ind.obvTrend==='confirmation'?'TEYIT':'NOTR',ind.obvTrend==='accumulation'?'var(--green)':ind.obvTrend==='distribution'?'var(--red)':'var(--t1)');$('iOBVs',ind.obvTrend==='accumulation'?'Akilli para aliyor':ind.obvTrend==='distribution'?'Akilli para satiyor':'Belirsiz');
  $('iVWAP',ind.vwap?ind.vwap.toFixed(2):'—',ind.lastClose>(ind.vwap||0)?'var(--green)':'var(--red)');$('iVWAPs',ind.vwap?(ind.lastClose>ind.vwap?'Ustunde — Guclu':'Altinda — Zayif'):'—');

  var rc=document.getElementById('results');
  var html='<div class="sig-card '+sig.cls+' fi"><div class="sig-lbl">Teknik Sinyal</div><div class="sig-val">'+sig.signal+'</div><div class="conf-bar"><div class="conf-fill" style="width:'+sig.conf+'%;background:'+(sig.cls==='buy'?'linear-gradient(135deg,var(--green),#00c853)':sig.cls==='sell'?'linear-gradient(135deg,var(--red),#d50000)':'linear-gradient(135deg,var(--yellow),var(--orange))')+'"></div></div><div class="conf-txt">Güven: %'+sig.conf+' · Skor: '+sig.score.toFixed(1)+'</div></div>';
  html+='<div class="trade-box fi"><div class="trade-title" style="color:var(--cyan)">Islem Kurulumu</div>';
  html+='<div class="tr-row"><span class="tr-l">Giris</span><span class="tr-v b">'+sig.entry.toFixed(2)+' TL</span></div>';
  html+='<div class="tr-row"><span class="tr-l">Stop-Loss</span><span class="tr-v r">'+sig.stop.toFixed(2)+' TL ('+(((sig.stop-sig.entry)/sig.entry)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="tr-row"><span class="tr-l">Hedef 1</span><span class="tr-v g">'+sig.t1.toFixed(2)+' TL (+'+(((sig.t1-sig.entry)/sig.entry)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="tr-row"><span class="tr-l">Hedef 2</span><span class="tr-v g">'+sig.t2.toFixed(2)+' TL (+'+(((sig.t2-sig.entry)/sig.entry)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="tr-row"><span class="tr-l">Hedef 3</span><span class="tr-v g">'+sig.t3.toFixed(2)+' TL (+'+(((sig.t3-sig.entry)/sig.entry)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="tr-row"><span class="tr-l">R/O</span><span class="tr-v y">1:'+sig.rr.toFixed(1)+'</span></div>';
  if(sig.atr)html+='<div class="tr-row"><span class="tr-l">ATR(14)</span><span class="tr-v" style="color:var(--cyan)">'+sig.atr.toFixed(2)+'</span></div>';
  html+='<div style="border-top:1px solid var(--border);margin-top:6px;padding-top:8px">';
  html+='<div class="tr-row"><span class="tr-l">Tutma Suresi</span><span class="tr-v" style="color:var(--purple)">'+(sig.holdText||'Belirtilemiyor')+'</span></div>';
  html+='<div class="tr-row"><span class="tr-l">Gunluk Ort Hareket</span><span class="tr-v" style="color:var(--cyan)">%'+(sig.dailyRange?sig.dailyRange.toFixed(2):'—')+'</span></div>';
  if(sig.dailyRange>0){
    html+='<div class="tr-row"><span class="tr-l">Gun Ici Hedef</span><span class="tr-v g">'+sig.intradayTarget.toFixed(2)+' TL</span></div>';
    html+='<div class="tr-row"><span class="tr-l">Gun Ici Stop</span><span class="tr-v r">'+sig.intradayStop.toFixed(2)+' TL</span></div>';
  }
  html+='</div></div>';
  html+='<div class="a-sec fi"><div class="trade-title">Gerekçeler</div>'+sig.reasons.map(function(r){return'<div class="a-item '+r.c+'"><div class="a-item-t">'+(r.c==='bullish'?'▲':r.c==='bearish'?'▼':'◆')+' '+(r.c==='bullish'?'Yukselis':r.c==='bearish'?'Dusus':'Notr')+'</div><div class="a-item-d">'+r.t+'</div></div>'}).join('')+'</div>';

  // Position Sizing Calculator
  html+='<div class="trade-box fi"><div class="trade-title" style="color:var(--cyan)">Pozisyon Boyutlandirici</div>';
  html+='<div style="display:flex;gap:6px;margin-bottom:8px"><input type="number" class="inp" id="accountSize" placeholder="Hesap (TL)" value="10000" style="font-size:10px;padding:6px"><input type="number" class="inp" id="riskPct" placeholder="Risk %" value="2" style="font-size:10px;padding:6px;width:60px"><button class="btn btn-go" onclick="calcPos()" style="font-size:9px;padding:6px 10px;width:auto;white-space:nowrap">HESAPLA</button></div>';
  html+='<div id="posResult" style="font-size:10px;color:var(--t3)">Hesap buyuklugunuzu girip Hesapla\'ya basin.</div></div>';

  // BACKTEST section
  html += '<div class="trade-box fi"><div class="trade-title" style="color:var(--cyan)">⚡ Backtest (Gecmis Veri Testi)</div>';
  html += '<div style="display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap">';
  html += '<button class="btn btn-go" onclick="runInlineBacktest(\x27signal\x27)" style="font-size:9px;padding:5px 8px;width:auto;background:linear-gradient(135deg,var(--cyan),var(--blue))">Sinyal</button>';
  html += '<button class="btn btn-go" onclick="runInlineBacktest(\x27rsi\x27)" style="font-size:9px;padding:5px 8px;width:auto;background:var(--bg0);color:var(--t2);border:1px solid var(--border)">RSI</button>';
  html += '<button class="btn btn-go" onclick="runInlineBacktest(\x27macd\x27)" style="font-size:9px;padding:5px 8px;width:auto;background:var(--bg0);color:var(--t2);border:1px solid var(--border)">MACD</button>';
  html += '<button class="btn btn-go" onclick="runInlineBacktest(\x27ma\x27)" style="font-size:9px;padding:5px 8px;width:auto;background:var(--bg0);color:var(--t2);border:1px solid var(--border)">MA Cross</button>';
  html += '</div>';
  html += '<div id="btInlineResults" style="display:none"></div>';
  html += '</div>';

  // AI Expert Box placeholder - triggerAI() fills this
  html+='<div class="ai-box fi" id="aiExpertBox"><div class="ai-hdr"><div class="ai-avatar">C</div>Claude Opus 4.6 · Wall Street Uzmanı</div><div id="aiExpertContent" style="color:var(--t3);font-size:10px">Yükleniyor...</div></div>';

  rc.innerHTML=html;

  // ===== BELOW CHART SECTION =====
  var bc = document.getElementById('belowChart');
  if (bc) {
    bc.style.display = 'block';
    var h2 = '';

    // Fundamental data
    h2 += '<div class="trade-box fi" id="fundBox"><div class="trade-title" style="color:var(--orange)">Temel Analiz Verileri</div><div id="fundContent" style="font-size:10px;color:var(--t3)">Yukleniyor...</div></div>';

    // Monte Carlo simulation
    if (G_data && G_data.prices.length > 30) {
      var mc = monteCarlo(G_data.prices, 20, 500);
      h2 += '<div class="trade-box fi"><div class="trade-title" style="color:var(--purple)">Monte Carlo Simulasyonu (20 gun, 500 senaryo)</div>';
      h2 += '<div id="mcChart"></div>';
      h2 += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:8px;font-size:10px">';
      h2 += '<div class="tr-row"><span class="tr-l">Kar Olasiligi</span><span class="tr-v g">%' + mc.profitProb.toFixed(0) + '</span></div>';
      h2 += '<div class="tr-row"><span class="tr-l">Medyan Hedef</span><span class="tr-v" style="color:var(--cyan)">' + mc.median.toFixed(2) + ' TL</span></div>';
      h2 += '<div class="tr-row"><span class="tr-l">En Kotusu (%5)</span><span class="tr-v r">' + mc.worst5.toFixed(2) + ' TL</span></div>';
      h2 += '<div class="tr-row"><span class="tr-l">En Iyisi (%95)</span><span class="tr-v g">' + mc.best5.toFixed(2) + ' TL</span></div>';
      h2 += '</div></div>';
    }

    // Trailing stop strategy
    if (sig.atr) {
      h2 += '<div class="trade-box fi"><div class="trade-title" style="color:var(--orange)">Profesyonel Cikis Stratejisi</div>';
      h2 += '<div style="font-size:10px;color:var(--t2);line-height:1.7">';
      h2 += '1. <b style="color:var(--blue)">Giris:</b> ' + sig.entry.toFixed(2) + ' TL<br>';
      h2 += '2. <b style="color:var(--green)">H1 (' + sig.t1.toFixed(2) + '):</b> Pozisyonun %50\'sini sat, kar al<br>';
      h2 += '3. <b style="color:var(--yellow)">Stop\'u girise cek:</b> ' + sig.entry.toFixed(2) + ' TL (breakeven)<br>';
      h2 += '4. <b style="color:var(--cyan)">Trailing Stop:</b> Geri kalan %50 icin ' + (sig.atr*2).toFixed(2) + ' TL mesafe ile takip<br>';
      h2 += '5. <b style="color:var(--purple)">Max hedef:</b> ' + sig.t3.toFixed(2) + ' TL veya trailing stop tetiklenene kadar';
      h2 += '</div></div>';
    }

    // Watchlist + Portfolio buttons
    h2 += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">';
    h2 += '<div class="trade-box fi" style="margin:0"><div class="trade-title" style="color:var(--yellow)">Watchlist\'e Ekle</div>';
    h2 += '<div style="display:flex;gap:4px;flex-wrap:wrap"><input type="number" class="inp" id="wlTargetUp" placeholder="Hedef" value="' + sig.t1.toFixed(2) + '" style="width:70px;font-size:10px;padding:6px"><input type="number" class="inp" id="wlTargetDn" placeholder="Stop" value="' + sig.stop.toFixed(2) + '" style="width:70px;font-size:10px;padding:6px">';
    h2 += '<button class="btn btn-go" onclick="addWatchlistFromAnalysis()" style="font-size:9px;padding:6px 10px;width:auto;background:linear-gradient(135deg,var(--yellow),var(--orange))">🔔</button></div></div>';
    h2 += '<div class="trade-box fi" style="margin:0"><div class="trade-title" style="color:var(--green)">Portfoye Ekle</div>';
    h2 += '<div style="display:flex;gap:4px"><input type="number" class="inp" id="addLot" value="1" min="1" style="width:50px;font-size:10px;padding:6px"><button class="btn btn-go" onclick="addFromAnalysis()" style="font-size:9px;padding:6px 10px;width:auto;background:linear-gradient(135deg,var(--green),#00c853)">EKLE</button></div></div>';
    h2 += '</div>';

    bc.innerHTML = h2;
  }
}

async function doAnalyze(){var sym=document.getElementById('symInp').value.trim().toUpperCase();if(!sym)return;var btn=document.getElementById('goBtn');btn.disabled=true;btn.textContent='⟳ ÇEKİLİYOR...';setBadge('Yükleniyor','load');document.getElementById('logBox').innerHTML='';var data=await fetchData(sym,document.getElementById('rangeInp').value,document.getElementById('intInp').value);if(!data){btn.disabled=false;btn.textContent='▶ ANALİZ ET';setBadge('Hata','err');document.getElementById('results').innerHTML='<div style="padding:20px;text-align:center;color:var(--red)">Veri cekilemedi.<br><button class="btn btn-demo" onclick="loadDemo()" style="margin-top:8px">Demo Veri ile Devam Et</button></div>';return}G_data=data;G_ind=calcAll(data.prices);G_sig=genSignal(G_ind,data.prices);drawChart(data.prices,G_ind);updateUI(data,G_ind,G_sig);postUpdateUI();loadFundamentals(sym);btn.disabled=false;btn.textContent='▶ ANALİZ ET';setBadge('Tamam','ok');triggerAI()}

// Trigger AI Expert Analysis - auto called after analysis
// Render Monte Carlo chart after UI update
function postUpdateUI() {
  if (G_data && G_data.prices.length > 30) {
    var mc = monteCarlo(G_data.prices, 20, 500);
    var mcEl = document.getElementById('mcChart');
    if (mcEl) renderMonteCarlo(mc, mcEl);
  }
}

async function triggerAI(){
  if(!G_data||!G_ind||!G_sig)return;
  var box=document.getElementById('aiExpertBox');
  if(!box)return;
  box.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Claude Opus 4.6 · Wall Street Uzmanı</div>'+
    '<div id="aiExpertContent"><div class="spinner"></div> Claude haberleri araştırıyor ve analiz ediyor...<div class="load-bar"><div class="load-fill"></div></div></div>';

  var prompt=buildExpertPrompt(G_data.symbol,G_ind,G_sig);
  var text=await callClaude(prompt, true);

  if(text && text.indexOf('Hata')===-1 && text.indexOf('API Hatası')===-1){
    box.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Claude Opus 4.6 · Wall Street Uzmanı</div><div class="ai-content">'+text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</div>';
  } else if(text) {
    // Show error with retry button
    box.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Claude Opus 4.6 · Wall Street Uzmanı</div>'+
      '<div id="aiExpertContent" style="color:var(--orange);font-size:10px;margin-bottom:10px">'+text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</div>'+
      '<button class="btn btn-go" onclick="triggerAI()" style="background:linear-gradient(135deg,var(--purple),#7c4dff);font-size:10px;padding:8px">🔄 Tekrar Dene</button>';
  } else {
    // No response - show manual button
    box.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Claude Opus 4.6 · Wall Street Uzmanı</div>'+
      '<div id="aiExpertContent" style="color:var(--t3);font-size:10px;margin-bottom:10px">Claude.ai\'da otomatik çalışır. Standalone kullanımda sol panelden API Key girin.</div>'+
      '<button class="btn btn-go" onclick="triggerAI()" style="background:linear-gradient(135deg,var(--purple),#7c4dff);font-size:10px;padding:8px">🧠 AI UZMAN YORUMU AL</button>';
  }
}

function loadDemo(){
  var sym=document.getElementById('symInp').value.trim().toUpperCase()||'THYAO';
  setBadge('Demo','demo');document.getElementById('logBox').innerHTML='';
  log(sym+' icin demo veri uretiliyor...','info');
  var data=generateDemoData(sym,180);
  G_data=data;G_ind=calcAll(data.prices);G_sig=genSignal(G_ind,data.prices);
  drawChart(data.prices,G_ind);updateUI(data,G_ind,G_sig);postUpdateUI();
  log(data.prices.length+' bar demo veri yuklendi — backtest calismaya hazir','ok');
}
renderWatchlist();
// Auto-check watchlist every 5 minutes
setInterval(checkWatchlistAlerts, 300000);

window.addEventListener('resize',function(){if(G_data&&G_ind)drawChart(G_data.prices,G_ind)});

// ====== SCANNER ======
function processScanStock(sym,data){
  var ind=calcAll(data.prices);var sig=genSignal(ind,data.prices);
  return{symbol:sym,price:ind.lastClose,change:ind.changePct,signal:sig.signal,cls:sig.cls,score:sig.score,conf:sig.conf,rsi:ind.lastRSI,rr:sig.rr,rr2:sig.rr2,entry:sig.entry,stop:sig.stop,target:sig.t1,target2:sig.t2,target3:sig.t3,reasons:sig.reasons,ma20:ind.lastMA20,ma50:ind.lastMA50,ma20pct:sig.ma20pct,ma50pct:sig.ma50pct,bollPct:sig.bollPct,volRatio:ind.volRatio,macd:ind.lastMACD,macdSig:ind.lastMACDSig,atr:sig.atr,mfi:ind.mfi,obvTrend:ind.obvTrend,vwap:ind.vwap,sector:SECTORS[sym]||'Diger',source:data.source,holdText:sig.holdText,holdBars:sig.holdBars,dailyRange:sig.dailyRange,intradayTarget:sig.intradayTarget,intradayStop:sig.intradayStop,intradayRR:sig.intradayRR};
}

async function startScan(){if(scanRunning)return;scanRunning=true;scanResults=[];expandedRow=null;var stocks=getStockList();var total=stocks.length,ok=0,fail=0,failedSyms=[];
  document.getElementById('scanBtn').style.display='none';document.getElementById('scanStopBtn').style.display='inline-block';document.getElementById('aiPicksBtn').style.display='none';
  document.getElementById('scanProgress').classList.add('visible');document.getElementById('scanSummary').style.display='grid';
  document.getElementById('scanEmpty').style.display='none';document.getElementById('scanTableWrap').style.display='block';document.getElementById('scanBody').innerHTML='';setBadge('Taraniyor','load');

  var BATCH=3;var delay=function(ms){return new Promise(function(r){setTimeout(r,ms)})};

  // PASS 1: Main scan
  for(var i=0;i<stocks.length;i+=BATCH){
    if(!scanRunning)break;var batch=stocks.slice(i,i+BATCH);
    var promises=batch.map(function(sym){
      return fetchSingle(sym,'6mo','1d',true).then(function(data){
        if(!data||data.prices.length<20){failedSyms.push(sym);fail++;return null}
        ok++;scanResults.push(processScanStock(sym,data));return true;
      }).catch(function(){failedSyms.push(sym);fail++;return null});
    });
    await Promise.all(promises);
    var done=ok+fail;var pct=Math.round(done/total*100);
    document.getElementById('spFill').style.width=pct+'%';document.getElementById('spPct').textContent=pct+'%';
    document.getElementById('spLabel').textContent='Tarama: '+batch.join(', ');
    document.getElementById('spOk').textContent=ok;document.getElementById('spFail').textContent=fail;document.getElementById('spLeft').textContent=(total-done);
    var buys=0,holds=0,sells=0;for(var j=0;j<scanResults.length;j++){if(scanResults[j].cls==='buy')buys++;else if(scanResults[j].cls==='sell')sells++;else holds++}
    document.getElementById('ssTotal').textContent=ok;document.getElementById('ssBuy').textContent=buys;document.getElementById('ssHold').textContent=holds;document.getElementById('ssSell').textContent=sells;
    renderSectorMap();renderScanTable();
    await delay(400);
  }

  // PASS 2: Retry failed stocks (one at a time, slower)
  if(failedSyms.length>0&&scanRunning){
    document.getElementById('spLabel').textContent='Hatali '+failedSyms.length+' hisse tekrar deneniyor...';
    var retryOk=0;
    for(var ri=0;ri<failedSyms.length;ri++){
      if(!scanRunning)break;
      var sym=failedSyms[ri];
      document.getElementById('spLabel').textContent='Tekrar: '+sym+' ('+(ri+1)+'/'+failedSyms.length+')';
      try{
        var data=await fetchSingle(sym,'6mo','1d',true);
        if(data&&data.prices.length>=20){
          scanResults.push(processScanStock(sym,data));
          retryOk++;ok++;fail--;
          document.getElementById('spOk').textContent=ok;document.getElementById('spFail').textContent=fail;
          renderScanTable();
        }
      }catch(e){}
      await delay(600);
    }
    if(retryOk>0){
      var buys=0,holds=0,sells=0;for(var j=0;j<scanResults.length;j++){if(scanResults[j].cls==='buy')buys++;else if(scanResults[j].cls==='sell')sells++;else holds++}
      document.getElementById('ssTotal').textContent=ok;document.getElementById('ssBuy').textContent=buys;document.getElementById('ssHold').textContent=holds;document.getElementById('ssSell').textContent=sells;
      renderSectorMap();
    }
  }

  scanRunning=false;document.getElementById('scanBtn').style.display='inline-block';document.getElementById('scanStopBtn').style.display='none';
  document.getElementById('spLabel').textContent='Tamamlandi! ('+ok+' basarili, '+fail+' hata)';setBadge('Tamam','ok');
  if(scanResults.length>0){document.getElementById('aiPicksBtn').style.display='inline-block'}
}
function stopScan(){scanRunning=false;document.getElementById('scanBtn').style.display='inline-block';document.getElementById('scanStopBtn').style.display='none';if(scanResults.length>0)document.getElementById('aiPicksBtn').style.display='inline-block';document.getElementById('spLabel').textContent='Durduruldu.';setBadge('Durduruldu','err')}
function filterScan(f,el){scanFilter=f;document.querySelectorAll('.sf-btn').forEach(function(b){b.className='sf-btn'});el.classList.add(f==='sell'?'active-r':f==='hold'?'active-y':'active');renderScanTable()}
function sortScan(key){if(scanSortKey===key)scanSortDir*=-1;else{scanSortKey=key;scanSortDir=(key==='symbol'?1:-1)}renderScanTable()}

function renderScanTable(){var filtered=scanResults.filter(function(r){
    if(scanFilter==='all')return true;
    if(scanFilter==='buy'||scanFilter==='hold'||scanFilter==='sell')return r.cls===scanFilter;
    if(scanFilter==='accumulation')return r.obvTrend==='accumulation';
    if(scanFilter==='highvol')return r.dailyRange&&r.dailyRange>2;
    return true;
  });filtered.sort(function(a,b){var va,vb;if(scanSortKey==='symbol'){va=a.symbol;vb=b.symbol;return scanSortDir*(va<vb?-1:va>vb?1:0)}if(scanSortKey==='signal'){var ord={buy:3,hold:2,sell:1};va=ord[a.cls]||0;vb=ord[b.cls]||0}else if(scanSortKey==='rr'){va=a.rr||0;vb=b.rr||0}else if(scanSortKey==='rsi'){va=a.rsi||50;vb=b.rsi||50}else{va=a[scanSortKey]||0;vb=b[scanSortKey]||0}return scanSortDir*(va-vb)});
  var body=document.getElementById('scanBody');var html='';
  for(var i=0;i<filtered.length;i++){var r=filtered[i];var isExp=expandedRow===r.symbol;
    html+='<tr'+(isExp?' style="background:var(--bg3)"':'')+'><td><span class="s-sym" onclick="goToAnalysis(\''+r.symbol+'\')">'+r.symbol+'</span></td><td><span class="s-signal '+r.cls+'">'+r.signal+'</span></td><td style="color:'+(r.score>=2?'var(--green)':r.score<=-2?'var(--red)':'var(--yellow)')+'">'+r.score.toFixed(1)+'</td><td>'+r.price.toFixed(2)+'</td><td class="'+(r.change>=0?'s-up':'s-dn')+'">'+(r.change>=0?'+':'')+r.change.toFixed(2)+'%</td><td style="color:'+(r.rsi&&r.rsi<30?'var(--green)':r.rsi&&r.rsi>70?'var(--red)':'var(--t1)')+'">'+(r.rsi?r.rsi.toFixed(1):'—')+'</td><td style="color:var(--yellow)">1:'+(r.rr?r.rr.toFixed(1):'—')+'</td><td style="color:var(--blue)">'+r.entry.toFixed(2)+'</td><td style="color:var(--red)">'+r.stop.toFixed(2)+'</td><td style="color:var(--green)">'+r.target.toFixed(2)+'</td><td><span class="qs" onclick="toggleDetail(\''+r.symbol+'\')" style="font-size:9px">'+(isExp?'▲':'▼')+'</span></td></tr>';
    if(isExp)html+='<tr><td colspan="11">'+buildDetail(r)+'</td></tr>'}
  body.innerHTML=html}

function buildDetail(r){var pc=r.cls==='sell'?'detail-panel sell-detail':r.cls==='hold'?'detail-panel hold-detail':'detail-panel';
  var ma20c=r.ma20pct>=0?'var(--green)':'var(--red)';var ma50c=r.ma50pct>=0?'var(--green)':'var(--red)';
  var html='<div class="'+pc+'"><div class="dp-grid"><div class="dp-section"><div class="dp-title">İşlem Kurulumu</div>';
  html+='<div class="dp-row"><span class="l">Giriş</span><span class="v" style="color:var(--blue)">'+r.entry.toFixed(2)+' ₺</span></div>';
  html+='<div class="dp-row"><span class="l">Stop-Loss</span><span class="v" style="color:var(--red)">'+r.stop.toFixed(2)+' ₺ ('+(((r.stop-r.price)/r.price)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="dp-row"><span class="l">Hedef 1</span><span class="v" style="color:var(--green)">'+r.target.toFixed(2)+' ₺ (+'+(((r.target-r.price)/r.price)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="dp-row"><span class="l">Hedef 2</span><span class="v" style="color:var(--green)">'+r.target2.toFixed(2)+' TL (+'+(((r.target2-r.price)/r.price)*100).toFixed(1)+'%)</span></div>';
  if(r.target3)html+='<div class="dp-row"><span class="l">Hedef 3</span><span class="v" style="color:var(--green)">'+r.target3.toFixed(2)+' TL (+'+(((r.target3-r.price)/r.price)*100).toFixed(1)+'%)</span></div>';
  html+='<div class="dp-row"><span class="l">R/O</span><span class="v" style="color:var(--yellow)">1:'+(r.rr?r.rr.toFixed(1):'—')+'</span></div>';
  html+='<div class="dp-row"><span class="l">Güven</span><span class="v">%'+r.conf+'</span></div></div>';
  html+='<div class="dp-section"><div class="dp-title">Göstergeler</div>';
  html+='<div class="dp-row"><span class="l">RSI</span><span class="v" style="color:'+(r.rsi&&r.rsi<30?'var(--green)':r.rsi&&r.rsi>70?'var(--red)':'var(--t1)')+'">'+(r.rsi?r.rsi.toFixed(1):'—')+'</span></div>';
  html+='<div class="dp-row"><span class="l">MACD</span><span class="v" style="color:'+(r.macd>0?'var(--green)':'var(--red)')+'">'+(r.macd!=null?r.macd.toFixed(2):'—')+'</span></div>';
  html+='<div class="dp-row"><span class="l">MA-20</span><span class="v">'+(r.ma20?r.ma20.toFixed(2):'—')+' <span style="color:'+ma20c+';font-size:9px">'+(r.ma20pct!=null?(r.ma20pct>=0?'+':'')+r.ma20pct.toFixed(1)+'%':'')+'</span></span></div>';
  html+='<div class="dp-row"><span class="l">MA-50</span><span class="v">'+(r.ma50?r.ma50.toFixed(2):'—')+' <span style="color:'+ma50c+';font-size:9px">'+(r.ma50pct!=null?(r.ma50pct>=0?'+':'')+r.ma50pct.toFixed(1)+'%':'')+'</span></span></div>';
  html+='<div class="dp-row"><span class="l">Hacim</span><span class="v">'+(r.volRatio?r.volRatio.toFixed(1)+'x':'—')+'</span></div>';
  html+='<div class="dp-row"><span class="l">MFI</span><span class="v" style="color:'+(r.mfi!=null&&r.mfi<20?'var(--green)':r.mfi!=null&&r.mfi>80?'var(--red)':'var(--t1)')+'">'+(r.mfi!=null?r.mfi.toFixed(0):'—')+'</span></div>';
  html+='<div class="dp-row"><span class="l">Akilli Para</span><span class="v" style="color:'+(r.obvTrend==='accumulation'?'var(--green)':r.obvTrend==='distribution'?'var(--red)':'var(--t1)')+'">'+(r.obvTrend==='accumulation'?'BIRIKIM':r.obvTrend==='distribution'?'DAGILIM':'Notr')+'</span></div>';
  html+='<div class="dp-row"><span class="l">Sektor</span><span class="v" style="color:var(--cyan)">'+(r.sector||'—')+'</span></div>';
  html+='</div>';
  html+='<div class="dp-section"><div class="dp-title">Gerekçeler</div><ul class="dp-reasons">';
  for(var i=0;i<r.reasons.length;i++){var reason=r.reasons[i];html+='<li class="'+(reason.c==='bullish'?'bull':reason.c==='bearish'?'bear':'neut')+'">'+reason.t+'</li>'}
  html+='</ul></div></div></div>';return html}

function toggleDetail(sym){expandedRow=expandedRow===sym?null:sym;renderScanTable()}
// Sector Heatmap
function renderSectorMap(){
  var map=document.getElementById('sectorMap');
  var grid=document.getElementById('sectorGrid');
  if(!map||!grid||scanResults.length<3)return;
  map.style.display='block';
  var rotation=analyzeSectorRotation(scanResults);
  var html='';
  for(var k=0;k<rotation.length;k++){
    var s=rotation[k];
    var bg=s.flowScore>2?'var(--green2)':s.flowScore<-1?'var(--red2)':'var(--bg4)';
    var bc=s.flowScore>2?'var(--green)':s.flowScore<-1?'var(--red)':'var(--border2)';
    var tc=s.flowScore>2?'var(--green)':s.flowScore<-1?'var(--red)':'var(--t2)';
    var arrow=s.flowScore>2?'▲':s.flowScore<-1?'▼':'▬';
    html+='<div style="background:'+bg+';border:1px solid '+bc+';border-radius:5px;padding:8px 12px;min-width:130px;flex:1">';
    html+='<div style="font-size:10px;font-weight:700;color:'+tc+'">'+arrow+' '+s.sector+'</div>';
    html+='<div style="font-size:9px;color:var(--t3);margin-top:2px">'+s.count+' hisse | Akis: '+s.flowScore.toFixed(1)+'</div>';
    html+='<div style="font-size:9px;margin-top:2px"><span style="color:var(--green)">'+s.buys+' AL</span> <span style="color:var(--red)">'+s.sells+' SAT</span>';
    if(s.accPct>0)html+=' <span style="color:var(--cyan)">'+s.accPct.toFixed(0)+'% birikim</span>';
    html+='</div></div>';
  }
  grid.innerHTML=html;
}

function goToAnalysis(sym){document.getElementById('symInp').value=sym;switchTab('analyze');doAnalyze()}

// Add to watchlist from analysis
function addWatchlistFromAnalysis() {
  if (!G_data) return;
  var up = parseFloat(document.getElementById('wlTargetUp').value) || null;
  var dn = parseFloat(document.getElementById('wlTargetDn').value) || null;
  addToWatchlist(G_data.symbol, up, dn);
  switchTab('portfolio');
}

function addWatchlistFromUI() {
  var sym = document.getElementById('wlSymbol').value.trim().toUpperCase();
  if (!sym) return;
  var up = parseFloat(document.getElementById('wlUp').value) || null;
  var dn = parseFloat(document.getElementById('wlDown').value) || null;
  addToWatchlist(sym, up, dn);
  document.getElementById('wlSymbol').value = '';
  document.getElementById('wlUp').value = '';
  document.getElementById('wlDown').value = '';
}

// Load fundamental data after analysis
async function loadFundamentals(symbol) {
  var el = document.getElementById('fundContent');
  if (!el) return;
  var fund = await fetchFundamentals(symbol);
  if (!fund) {
    el.innerHTML = '<span style="color:var(--t3)">Temel veri alinamadi.</span>';
    return;
  }
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:4px">';
  if (fund.pe) html += '<div class="tr-row"><span class="tr-l">F/K</span><span class="tr-v" style="color:'+(fund.pe<10?'var(--green)':fund.pe>25?'var(--red)':'var(--t1)')+'">'+fund.pe.toFixed(1)+'</span></div>';
  if (fund.pb) html += '<div class="tr-row"><span class="tr-l">PD/DD</span><span class="tr-v" style="color:'+(fund.pb<1?'var(--green)':fund.pb>3?'var(--red)':'var(--t1)')+'">'+fund.pb.toFixed(2)+'</span></div>';
  if (fund.divYield) html += '<div class="tr-row"><span class="tr-l">Temettu</span><span class="tr-v g">%'+fund.divYield.toFixed(1)+'</span></div>';
  if (fund.roe) html += '<div class="tr-row"><span class="tr-l">ROE</span><span class="tr-v" style="color:'+(fund.roe>15?'var(--green)':'var(--t1)')+'">%'+fund.roe.toFixed(1)+'</span></div>';
  if (fund.marketCap) html += '<div class="tr-row"><span class="tr-l">Piyasa Deg.</span><span class="tr-v">'+(fund.marketCap/1e9).toFixed(1)+' Milyar</span></div>';
  if (fund.targetPrice) html += '<div class="tr-row"><span class="tr-l">Analist Hedef</span><span class="tr-v g">'+fund.targetPrice.toFixed(2)+' TL</span></div>';
  if (fund.recommendation) html += '<div class="tr-row"><span class="tr-l">Analist</span><span class="tr-v" style="color:'+(fund.recommendation==='buy'||fund.recommendation==='strong_buy'?'var(--green)':'var(--t1)')+'">'+fund.recommendation.toUpperCase()+'</span></div>';
  if (fund.profitMargin) html += '<div class="tr-row"><span class="tr-l">Kar Marji</span><span class="tr-v">%'+fund.profitMargin.toFixed(1)+'</span></div>';
  if (fund.revenueGrowth) html += '<div class="tr-row"><span class="tr-l">Gelir Buyumesi</span><span class="tr-v" style="color:'+(fund.revenueGrowth>0?'var(--green)':'var(--red)')+'">'+(fund.revenueGrowth>0?'+':'')+fund.revenueGrowth.toFixed(1)+'%</span></div>';
  if (fund.debtToEquity) html += '<div class="tr-row"><span class="tr-l">Borc/Ozsermaye</span><span class="tr-v" style="color:'+(fund.debtToEquity>100?'var(--red)':'var(--t1)')+'">'+fund.debtToEquity.toFixed(0)+'</span></div>';
  html += '</div>';
  // Value score
  var vScore = 0;
  if (fund.pe && fund.pe < 10) vScore += 2;
  else if (fund.pe && fund.pe < 15) vScore += 1;
  if (fund.pb && fund.pb < 1) vScore += 2;
  else if (fund.pb && fund.pb < 2) vScore += 1;
  if (fund.divYield && fund.divYield > 3) vScore += 1;
  if (fund.roe && fund.roe > 15) vScore += 1;
  if (fund.revenueGrowth && fund.revenueGrowth > 10) vScore += 1;
  var vLabel = vScore >= 4 ? 'Cok Ucuz' : vScore >= 2 ? 'Makul' : vScore >= 1 ? 'Pahalimsi' : 'Pahali';
  var vColor = vScore >= 4 ? 'var(--green)' : vScore >= 2 ? 'var(--yellow)' : 'var(--red)';
  html += '<div style="margin-top:8px;padding:8px;background:var(--bg0);border-radius:4px;text-align:center"><span style="font-size:9px;color:var(--t3)">Deger Skoru: </span><span style="font-weight:700;color:'+vColor+'">'+vLabel+' ('+vScore+'/7)</span></div>';
  el.innerHTML = html;
}

// Add to portfolio from analysis
function addFromAnalysis() {
  if (!G_sig || !G_data) return;
  var lots = parseInt(document.getElementById('addLot').value) || 1;
  addToPortfolio(G_data.symbol, lots, G_sig.entry, G_sig.stop, G_sig.t1);
  switchTab('portfolio');
}

// Position sizing calculator UI
function calcPos(){
  if(!G_sig)return;
  var acc=parseFloat(document.getElementById('accountSize').value)||10000;
  var rsk=parseFloat(document.getElementById('riskPct').value)||2;
  var pos=calcPosition(acc,rsk,G_sig.entry,G_sig.stop);
  var div=document.getElementById('posResult');
  if(pos.shares<=0){div.innerHTML='<span style="color:var(--red)">Stop mesafesi cok kucuk, hesaplanamadi.</span>';return}
  var t1Profit=pos.shares*(G_sig.t1-G_sig.entry);
  var t2Profit=pos.shares*(G_sig.t2-G_sig.entry);
  div.innerHTML='<div style="display:grid;gap:4px">'+
    '<div class="tr-row"><span class="tr-l">Lot Sayisi</span><span class="tr-v" style="color:var(--cyan)">'+pos.shares+' adet</span></div>'+
    '<div class="tr-row"><span class="tr-l">Pozisyon Maliyeti</span><span class="tr-v b">'+pos.cost.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL ('+(pos.costPct).toFixed(1)+'%)</span></div>'+
    '<div class="tr-row"><span class="tr-l">Max Kayip (%'+rsk+')</span><span class="tr-v r">'+pos.maxLoss.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</span></div>'+
    '<div class="tr-row"><span class="tr-l">H1 Kar</span><span class="tr-v g">+'+t1Profit.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</span></div>'+
    '<div class="tr-row"><span class="tr-l">H2 Kar</span><span class="tr-v g">+'+t2Profit.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</span></div>'+
  '</div>';
}

// ====== AI DAILY PICKS ======
async function aiDailyPicks(){
  if(scanResults.length<5){alert('Önce tarama yapın (en az 5 hisse).');return}
  var btn=document.getElementById('aiPicksBtn');btn.disabled=true;btn.textContent='🧠 ANALİZ EDİLİYOR...';
  var panel=document.getElementById('aiPicksPanel');panel.classList.add('visible');
  document.getElementById('aiPicksContent').innerHTML='<div class="spinner"></div> Claude Opus 4.6 tarama sonuçlarını analiz ediyor...\nWall Street perspektifinden günlük seçimler hazırlanıyor...\n<div class="load-bar"><div class="load-fill"></div></div>';

  var prompt=buildDailyPicksPrompt(scanResults);
  var text=await callClaude(prompt, true);

  if(text && text.indexOf('Hata')===-1 && text.indexOf('API Hatası')===-1){
    document.getElementById('aiPicksContent').innerHTML=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  } else {
    document.getElementById('aiPicksContent').innerHTML='<span style="color:var(--orange)">'+(text||'AI yanıt alınamadı.')+'</span>\n\n<span style="color:var(--t3);font-size:10px">Claude.ai\'da otomatik çalışır. Standalone kullanımda API Key gerekir.</span>';
  }
  btn.disabled=false;btn.textContent='🧠 AI GÜNLÜK SEÇİMLER'}

// ====== DAILY TRADE IDEAS ======
async function generateDailyTrades(){
  var btn=document.getElementById('tradeBtn');btn.disabled=true;btn.textContent='★ TARANIYOR...';
  var prog=document.getElementById('tradeProgress');prog.classList.add('visible');
  var sel=document.getElementById('tradeList').value;
  var stocks;
  if(sel==='bist30')stocks=BIST30.slice();
  else if(sel==='bist50')stocks=BIST50.slice();
  else stocks=BIST100.slice();

  var results=[];var total=stocks.length;
  var delay=function(ms){return new Promise(function(r){setTimeout(r,ms)})};

  for(var i=0;i<stocks.length;i+=3){
    var batch=stocks.slice(i,i+3);
    var promises=batch.map(function(sym){
      return fetchSingle(sym,'3mo','1d',true).then(function(data){
        if(!data||data.prices.length<20)return null;
        var ind=calcAll(data.prices);var sig=genSignal(ind,data.prices);
        results.push({symbol:sym,price:ind.lastClose,change:ind.changePct,signal:sig.signal,cls:sig.cls,score:sig.score,conf:sig.conf,rsi:ind.lastRSI,rr:sig.rr,entry:sig.entry,stop:sig.stop,target:sig.t1,target2:sig.t2,target3:sig.t3,reasons:sig.reasons,atr:sig.atr,mfi:ind.mfi,obvTrend:ind.obvTrend,volRatio:ind.volRatio,sector:SECTORS[sym]||'Diger',holdText:sig.holdText,holdBars:sig.holdBars,dailyRange:sig.dailyRange,intradayTarget:sig.intradayTarget,intradayStop:sig.intradayStop,intradayRR:sig.intradayRR});
      }).catch(function(){});
    });
    await Promise.all(promises);
    var pct=Math.round((i+batch.length)/total*100);
    document.getElementById('tpFill').style.width=pct+'%';
    document.getElementById('tpPct').textContent=pct+'%';
    document.getElementById('tpLabel').textContent=batch.join(', ');
    await delay(400);
  }

  document.getElementById('tpLabel').textContent=results.length+' hisse tarandi';

  // INTRADAY SCORING: filter by volatility + momentum + smart money
  // Higher daily range = more intraday opportunity
  var scored=results.filter(function(r){return r.dailyRange>0}).map(function(r){
    var intScore=0;
    // High daily volatility = more room for intraday profit
    if(r.dailyRange>3)intScore+=3;
    else if(r.dailyRange>2)intScore+=2;
    else if(r.dailyRange>1.5)intScore+=1;
    // Positive momentum today
    if(r.change>0.5)intScore+=2;
    if(r.change>1.5)intScore+=1;
    // Volume surge = institutional move starting
    if(r.volRatio>1.5)intScore+=2;
    if(r.volRatio>2.5)intScore+=1;
    // Smart money buying
    if(r.obvTrend==='accumulation')intScore+=2;
    // RSI not overbought (room to run)
    if(r.rsi&&r.rsi>40&&r.rsi<65)intScore+=1;
    if(r.rsi&&r.rsi<35)intScore+=2; // oversold bounce potential
    // MFI institutional buying
    if(r.mfi!=null&&r.mfi<25)intScore+=2;
    // Good R/R for intraday
    if(r.intradayRR>1.3)intScore+=1;
    r.intScore=intScore;
    return r;
  }).sort(function(a,b){return b.intScore-a.intScore});

  var top=scored.slice(0,7);
  var today=new Date().toLocaleDateString('tr-TR',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

  var html='';
  html+='<div style="text-align:center;margin-bottom:20px">';
  html+='<div style="font-family:Space Grotesk,sans-serif;font-size:22px;font-weight:700;color:var(--yellow)">★ Gunluk Intraday Trade Firsatlari</div>';
  html+='<div style="font-size:11px;color:var(--t3);margin-top:4px">'+today+' | '+results.length+' hisse | Gun ici al-sat firsatlari</div>';
  html+='<div style="font-size:10px;color:var(--orange);margin-top:6px;padding:6px 12px;background:var(--yellow2);border-radius:4px;display:inline-block">Strateji: Piyasa acilisinda gir, gun icinde karini al, kapanistan once cik</div>';
  html+='</div>';

  if(top.length===0){
    html+='<div style="text-align:center;padding:40px;color:var(--t3)">Bugun intraday firsat bulunamadi. Volatilite dusuk.</div>';
  }

  for(var i=0;i<top.length;i++){
    var r=top[i];
    var intGain=((r.intradayTarget-r.price)/r.price*100);
    var intLoss=((r.intradayStop-r.price)/r.price*100);
    var pos=calcPosition(10000,1,r.price,r.intradayStop); // 1% risk for intraday

    html+='<div style="background:linear-gradient(135deg,var(--bg3),var(--bg0));border:1px solid '+(r.intScore>=8?'var(--green)':r.intScore>=5?'var(--yellow)':'var(--border2)');
    html+=';border-radius:8px;padding:18px;margin-bottom:12px">';

    // Header
    html+='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">';
    html+='<div style="display:flex;align-items:center;gap:10px">';
    html+='<div style="background:'+(r.intScore>=8?'var(--green)':r.intScore>=5?'var(--yellow)':'var(--t3)');
    html+=';color:#000;font-family:Space Grotesk,sans-serif;font-size:20px;font-weight:700;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center">'+(i+1)+'</div>';
    html+='<div><div style="font-family:Space Grotesk,sans-serif;font-size:18px;font-weight:700;cursor:pointer;color:var(--t1)" onclick="goToAnalysis(\x27'+r.symbol+'\x27)">'+r.symbol+'</div>';
    html+='<div style="font-size:9px;color:var(--t3)">'+r.sector+' | Intraday Skor: '+r.intScore+' | Volatilite: %'+r.dailyRange.toFixed(1)+'</div></div></div>';
    html+='<div style="text-align:right"><div style="font-size:18px;font-weight:700">'+r.price.toFixed(2)+' TL</div>';
    html+='<div style="font-size:11px;color:'+(r.change>=0?'var(--green)':'var(--red)')+'">'+(r.change>=0?'+':'')+r.change.toFixed(2)+'%</div></div></div>';

    // INTRADAY Trade Grid
    html+='<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin-bottom:12px">';

    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid var(--blue)"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">Acilista Giris</div><div style="font-size:16px;font-weight:700;color:var(--blue)">'+r.price.toFixed(2)+' TL</div></div>';

    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid var(--red)"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">Gun Ici Stop</div><div style="font-size:16px;font-weight:700;color:var(--red)">'+r.intradayStop.toFixed(2)+' TL</div><div style="font-size:9px;color:var(--red)">'+intLoss.toFixed(2)+'%</div></div>';

    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid var(--green)"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">Gun Ici Hedef</div><div style="font-size:16px;font-weight:700;color:var(--green)">'+r.intradayTarget.toFixed(2)+' TL</div><div style="font-size:9px;color:var(--green)">+'+intGain.toFixed(2)+'%</div></div>';

    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid var(--yellow)"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">R/O (Intraday)</div><div style="font-size:16px;font-weight:700;color:var(--yellow)">1:'+(r.intradayRR?r.intradayRR.toFixed(1):'—')+'</div></div>';

    var smartMoney=r.obvTrend==='accumulation'?'BIRIKIM':r.obvTrend==='distribution'?'DAGILIM':'Notr';
    var smartColor=r.obvTrend==='accumulation'?'var(--green)':r.obvTrend==='distribution'?'var(--red)':'var(--t2)';
    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid '+smartColor+'"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">Akilli Para</div><div style="font-size:14px;font-weight:700;color:'+smartColor+'">'+smartMoney+'</div></div>';

    html+='<div style="background:var(--bg0);padding:10px;border-radius:5px;border-left:3px solid var(--purple)"><div style="font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--t3)">Kapanista</div><div style="font-size:14px;font-weight:700;color:var(--purple)">KAPAT</div><div style="font-size:9px;color:var(--t3)">Gecede tutma</div></div>';

    html+='</div>';

    // Position + Stats
    html+='<div style="display:flex;gap:12px;font-size:10px;color:var(--t2);flex-wrap:wrap;margin-bottom:8px">';
    html+='<span>RSI: <b style="color:'+(r.rsi<35?'var(--green)':r.rsi>65?'var(--red)':'var(--t1)')+'">'+(r.rsi?r.rsi.toFixed(0):'—')+'</b></span>';
    html+='<span>MFI: <b>'+(r.mfi!=null?r.mfi.toFixed(0):'—')+'</b></span>';
    html+='<span>Hacim: <b>'+r.volRatio.toFixed(1)+'x</b></span>';
    if(pos.shares>0)html+='<span>10K hesapta: <b style="color:var(--cyan)">'+pos.shares+' lot</b> | Max kayip: <b style="color:var(--red)">'+pos.maxLoss.toFixed(0)+' TL</b> | Hedef kar: <b style="color:var(--green)">'+(pos.shares*(r.intradayTarget-r.price)).toFixed(0)+' TL</b></span>';
    html+='</div>';

    // Timing advice
    html+='<div style="background:var(--bg0);padding:8px 12px;border-radius:5px;font-size:10px;color:var(--t2);border:1px dashed var(--border)">';
    html+='<b style="color:var(--yellow)">Zamanlama:</b> ';
    if(r.rsi&&r.rsi<35)html+='Acilis sonrasi ilk 30dk alis firsati. Oversold sicrama bekleniyor.';
    else if(r.volRatio>2)html+='Hacim patlamasi mevcut. Acilista agresif giris, hedefe ulasinca hemen kar al.';
    else if(r.change>1)html+='Momentum devam ediyor. Acilista pullback bekle (5-10dk), sonra gir.';
    else html+='Acilis sonrasi 15-30dk izle, yon netlesince gir. Sabahki ilk mumun kirilamini bekle.';
    html+='</div>';

    html+='</div>';
  }

  // Kacinilacaklar
  var danger=results.filter(function(r){return r.score<=-2||r.dailyRange<0.5||(r.obvTrend==='distribution'&&r.rsi>60)}).sort(function(a,b){return a.score-b.score}).slice(0,5);
  if(danger.length>0){
    html+='<div style="margin-top:16px;padding:16px;background:var(--red2);border:1px solid var(--red);border-radius:8px">';
    html+='<div style="font-size:12px;font-weight:700;color:var(--red);margin-bottom:8px">INTRADAY YAPMA — Bu hisselerden uzak dur</div>';
    for(var di=0;di<danger.length;di++){var d=danger[di];
      html+='<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:11px;border-bottom:1px solid var(--border)">';
      html+='<span style="font-weight:600;color:var(--red)">'+d.symbol+'</span>';
      html+='<span style="color:var(--t2)">Skor: '+d.score.toFixed(1)+' | Vol: %'+(d.dailyRange?d.dailyRange.toFixed(1):'—')+' | '+(d.obvTrend==='distribution'?'Dagilim':'Zayif')+'</span></div>';
    }
    html+='</div>';
  }

  // Intraday kurallar
  html+='<div style="margin-top:16px;padding:14px;background:var(--bg3);border:1px solid var(--border);border-radius:8px">';
  html+='<div style="font-size:11px;font-weight:700;color:var(--yellow);margin-bottom:6px">INTRADAY KURALLARI</div>';
  html+='<div style="font-size:10px;color:var(--t2);line-height:1.8">';
  html+='1. Hedefe ulasinca HEMEN kar al, daha yukari gider mi diye bekleme.<br>';
  html+='2. Stop\'a gelince HEMEN cik, ortalama dusurme.<br>';
  html+='3. Gun ici islem yapiyorsan 15:30\'dan sonra YENi pozisyon ACMA.<br>';
  html+='4. Tek islemde hesabinin max %1\'ini riske at (intraday icin).<br>';
  html+='5. Kapanisindan once TUM pozisyonlari kapat. Geceye tutma.<br>';
  html+='6. Ilk 15dk ve son 15dk en volatil zamanlar — dikkatli ol.</div></div>';

  html+='<div style="text-align:center;margin-top:12px;font-size:9px;color:var(--t3)">Bu analiz yatirim tavsiyesi degildir.</div>';
  document.getElementById('tradeResults').innerHTML=html;

  // AI Commentary
  if(top.length>0){
    var aiHtml='<div class="ai-box fi" id="tradeAIBox" style="margin:16px 0"><div class="ai-hdr"><div class="ai-avatar">C</div>Claude · Intraday Yorumu</div><div><div class="spinner"></div> Analiz ediliyor...</div><div class="load-bar"><div class="load-fill"></div></div></div>';
    document.getElementById('tradeResults').innerHTML+=aiHtml;
    var aiP='Sen Wall Street kidemli day trader\'isin. Bugunku BIST intraday firsatlari:\n';
    for(var ai=0;ai<Math.min(5,top.length);ai++){var r=top[ai];aiP+=(ai+1)+'. '+r.symbol+' ('+r.sector+') Fiyat:'+r.price.toFixed(2)+' Deg:'+(r.change>=0?'+':'')+r.change.toFixed(1)+'% Vol:'+r.volRatio.toFixed(1)+'x DailyRange:%'+r.dailyRange.toFixed(1)+' RSI:'+(r.rsi?r.rsi.toFixed(0):'—')+' AkilliPara:'+r.obvTrend+' IntScore:'+r.intScore+'\n'}
    aiP+='\nTurkce yaz. Bugun gun ici trade yapacagim. Her hisse icin:\n1. Tam olarak ne zaman girmeliyim (acilis, 30dk sonra, pullback bekle?)\n2. Kari ne zaman almaliyim (hedef fiyat)\n3. Ne olursa olsun ne zaman cikmaliyim\n4. En guvenilenler hangileri ve neden\nKisa net pratik. Yatirim tavsiyesi degildir.';
    var aiText=await callClaude(aiP,false);
    var aiBox=document.getElementById('tradeAIBox');
    if(aiBox){
      if(aiText&&aiText.indexOf('Hata')===-1&&aiText.indexOf('API Hatasi')===-1){
        aiBox.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Claude · Intraday Yorumu</div><div class="ai-content">'+aiText.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</div>';
      }else{
        aiBox.innerHTML='<div class="ai-hdr"><div class="ai-avatar">C</div>Intraday Yorum</div><div style="color:var(--t3);font-size:10px">AI yorumu yuklenemedi. Teknik veriler yukarida.</div>';
      }
    }
  }
  btn.disabled=false;btn.textContent='★ GUNUN FIRSATLARINI BUL';
}



// ========= MONTE CARLO SIMULATION =========
function monteCarlo(prices, days, sims) {
  days = days || 20; sims = sims || 500;
  var closes = prices.map(function(p){return p.close});
  var returns = [];
  for (var i = 1; i < closes.length; i++) returns.push(Math.log(closes[i]/closes[i-1]));
  var mu = returns.reduce(function(a,b){return a+b},0) / returns.length;
  var variance = returns.reduce(function(a,b){return a + Math.pow(b-mu,2)},0) / returns.length;
  var sigma = Math.sqrt(variance);
  var lastPrice = closes[closes.length-1];
  var paths = [];
  for (var s = 0; s < sims; s++) {
    var path = [lastPrice];
    for (var d = 0; d < days; d++) {
      var z = 0; for(var k=0;k<6;k++) z += Math.random(); z = (z-3)*1.4; // approx normal
      var ret = mu + sigma * z;
      path.push(path[path.length-1] * Math.exp(ret));
    }
    paths.push(path);
  }
  // Calculate percentiles at each day
  var p5=[],p25=[],p50=[],p75=[],p95=[];
  for (var d = 0; d <= days; d++) {
    var vals = paths.map(function(p){return p[d]}).sort(function(a,b){return a-b});
    p5.push(vals[Math.floor(sims*0.05)]);
    p25.push(vals[Math.floor(sims*0.25)]);
    p50.push(vals[Math.floor(sims*0.5)]);
    p75.push(vals[Math.floor(sims*0.75)]);
    p95.push(vals[Math.floor(sims*0.95)]);
  }
  var finalPrices = paths.map(function(p){return p[days]}).sort(function(a,b){return a-b});
  var profitProb = finalPrices.filter(function(p){return p > lastPrice}).length / sims * 100;
  return {p5:p5,p25:p25,p50:p50,p75:p75,p95:p95,days:days,profitProb:profitProb,
    median:p50[days],worst5:p5[days],best5:p95[days],lastPrice:lastPrice};
}

function renderMonteCarlo(mc, container) {
  var w=320,h=140,pad=30;
  var maxP=Math.max.apply(null,mc.p95), minP=Math.min.apply(null,mc.p5);
  var xS=function(i){return pad+(i/mc.days)*(w-pad*2)};
  var yS=function(p){return pad+(1-(p-minP)/(maxP-minP))*(h-pad*2)};
  var svg='<svg width="100%" viewBox="0 0 '+w+' '+h+'" style="display:block">';
  // P5-P95 band
  svg+='<polygon points="';
  for(var i=0;i<=mc.days;i++) svg+=xS(i)+','+yS(mc.p95[i])+' ';
  for(var i=mc.days;i>=0;i--) svg+=xS(i)+','+yS(mc.p5[i])+' ';
  svg+='" fill="#2979ff" opacity="0.08"/>';
  // P25-P75 band
  svg+='<polygon points="';
  for(var i=0;i<=mc.days;i++) svg+=xS(i)+','+yS(mc.p75[i])+' ';
  for(var i=mc.days;i>=0;i--) svg+=xS(i)+','+yS(mc.p25[i])+' ';
  svg+='" fill="#2979ff" opacity="0.15"/>';
  // Median line
  svg+='<polyline points="';
  for(var i=0;i<=mc.days;i++) svg+=xS(i)+','+yS(mc.p50[i])+' ';
  svg+='" fill="none" stroke="#00e676" stroke-width="1.5"/>';
  // Current price line
  svg+='<line x1="'+pad+'" y1="'+yS(mc.lastPrice)+'" x2="'+(w-pad)+'" y2="'+yS(mc.lastPrice)+'" stroke="#ffd600" stroke-width="0.5" stroke-dasharray="3,3"/>';
  // Labels
  svg+='<text x="'+(w-pad+2)+'" y="'+yS(mc.p95[mc.days])+'" fill="#4a5568" font-size="8" font-family="JetBrains Mono">%95: '+mc.best5.toFixed(1)+'</text>';
  svg+='<text x="'+(w-pad+2)+'" y="'+yS(mc.p50[mc.days])+'" fill="#00e676" font-size="8" font-family="JetBrains Mono">Med: '+mc.median.toFixed(1)+'</text>';
  svg+='<text x="'+(w-pad+2)+'" y="'+yS(mc.p5[mc.days])+'" fill="#ff1744" font-size="8" font-family="JetBrains Mono">%5: '+mc.worst5.toFixed(1)+'</text>';
  svg+='</svg>';
  container.innerHTML = svg +
    '<div style="display:flex;justify-content:space-between;font-size:9px;color:var(--t2);margin-top:4px">'+
    '<span>Kar olasiligi: <b style="color:var(--green)">%'+mc.profitProb.toFixed(0)+'</b></span>'+
    '<span>'+mc.days+' gun, 500 simulasyon</span></div>';
}

// ========= TRAILING STOP CALCULATOR =========
function calcTrailingStop(entry, atr, multiplier) {
  multiplier = multiplier || 2;
  return {
    initial: entry - atr * 1.5,
    trailing: atr * multiplier,
    partialAt: entry + atr * 1.5,  // take 50% profit here
    moveStopTo: entry,              // move stop to breakeven after partial
    description: 'Giris: ' + entry.toFixed(2) + ' | H1\'de %50 kar al, stop\'u girise cek, geri kalani trailing ' + (atr*multiplier).toFixed(2) + ' TL ile takip et'
  };
}

// ========= SECTOR ROTATION ANALYSIS =========
function analyzeSectorRotation(results) {
  var sectors = {};
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    var sec = r.sector || 'Diger';
    if (!sectors[sec]) sectors[sec] = {stocks:[],totalChange:0,totalScore:0,totalVol:0,buys:0,sells:0,count:0,accumulation:0};
    sectors[sec].stocks.push(r);
    sectors[sec].totalChange += r.change;
    sectors[sec].totalScore += r.score;
    sectors[sec].totalVol += (r.volRatio||1);
    sectors[sec].count++;
    if (r.cls==='buy') sectors[sec].buys++;
    if (r.cls==='sell') sectors[sec].sells++;
    if (r.obvTrend==='accumulation') sectors[sec].accumulation++;
  }
  var rotation = [];
  for (var sec in sectors) {
    var s = sectors[sec];
    var avgChg = s.totalChange / s.count;
    var avgScore = s.totalScore / s.count;
    var avgVol = s.totalVol / s.count;
    var accPct = s.accumulation / s.count * 100;
    // Money flow score: positive change + high volume + accumulation = money flowing IN
    var flowScore = avgChg * 0.4 + (avgVol - 1) * 2 + accPct * 0.03 + avgScore * 0.3;
    rotation.push({sector:sec, avgChange:avgChg, avgScore:avgScore, avgVol:avgVol, accPct:accPct,
      flowScore:flowScore, buys:s.buys, sells:s.sells, count:s.count, stocks:s.stocks});
  }
  rotation.sort(function(a,b){return b.flowScore - a.flowScore});
  return rotation;
}

// ========= VIRTUAL PORTFOLIO TRACKER =========
var portfolio = {positions:[],cash:10000,history:[]};

function addToPortfolio(symbol, shares, price, stop, target) {
  portfolio.positions.push({
    symbol:symbol, shares:shares, entryPrice:price, currentPrice:price,
    stop:stop, target:target, entryDate:new Date().toISOString(),
    pnl:0, pnlPct:0, status:'open'
  });
  portfolio.cash -= shares * price;
  portfolio.history.push({date:new Date().toISOString(), action:'BUY', symbol:symbol, shares:shares, price:price});
  renderPortfolio();
}

function closePosition(idx) {
  var pos = portfolio.positions[idx];
  if (!pos || pos.status !== 'open') return;
  portfolio.cash += pos.shares * pos.currentPrice;
  pos.status = 'closed';
  pos.pnl = (pos.currentPrice - pos.entryPrice) * pos.shares;
  pos.pnlPct = (pos.currentPrice - pos.entryPrice) / pos.entryPrice * 100;
  portfolio.history.push({date:new Date().toISOString(), action:'SELL', symbol:pos.symbol, shares:pos.shares, price:pos.currentPrice});
  renderPortfolio();
}

function renderPortfolio() {
  var el = document.getElementById('portfolioContent');
  if (!el) return;
  var totalValue = portfolio.cash;
  var totalPnl = 0;
  var openPos = portfolio.positions.filter(function(p){return p.status==='open'});
  for (var i = 0; i < openPos.length; i++) {
    totalValue += openPos[i].shares * openPos[i].currentPrice;
    totalPnl += (openPos[i].currentPrice - openPos[i].entryPrice) * openPos[i].shares;
  }
  var html = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:8px;margin-bottom:12px">';
  html += '<div style="background:var(--bg3);padding:10px;border-radius:5px;text-align:center"><div style="font-size:8px;text-transform:uppercase;color:var(--t3)">Toplam Deger</div><div style="font-size:16px;font-weight:700;color:var(--cyan)">'+totalValue.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</div></div>';
  html += '<div style="background:var(--bg3);padding:10px;border-radius:5px;text-align:center"><div style="font-size:8px;text-transform:uppercase;color:var(--t3)">Nakit</div><div style="font-size:16px;font-weight:700">'+portfolio.cash.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</div></div>';
  html += '<div style="background:var(--bg3);padding:10px;border-radius:5px;text-align:center"><div style="font-size:8px;text-transform:uppercase;color:var(--t3)">Kar/Zarar</div><div style="font-size:16px;font-weight:700;color:'+(totalPnl>=0?'var(--green)':'var(--red)')+'">'+(totalPnl>=0?'+':'')+totalPnl.toLocaleString('tr-TR',{maximumFractionDigits:0})+' TL</div></div>';
  html += '<div style="background:var(--bg3);padding:10px;border-radius:5px;text-align:center"><div style="font-size:8px;text-transform:uppercase;color:var(--t3)">Pozisyon</div><div style="font-size:16px;font-weight:700">'+openPos.length+'</div></div>';
  html += '</div>';

  if (openPos.length > 0) {
    html += '<div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--t3);margin-bottom:6px">Acik Pozisyonlar</div>';
    for (var i = 0; i < portfolio.positions.length; i++) {
      var p = portfolio.positions[i];
      if (p.status !== 'open') continue;
      var pnl = (p.currentPrice - p.entryPrice) * p.shares;
      var pnlPct = (p.currentPrice - p.entryPrice) / p.entryPrice * 100;
      html += '<div style="background:var(--bg3);border-left:3px solid '+(pnl>=0?'var(--green)':'var(--red)');
      html += ';border-radius:5px;padding:10px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center">';
      html += '<div><div style="font-weight:700;font-size:13px">'+p.symbol+'</div>';
      html += '<div style="font-size:9px;color:var(--t3)">'+p.shares+' lot @ '+p.entryPrice.toFixed(2)+' TL</div></div>';
      html += '<div style="text-align:right"><div style="font-weight:700;color:'+(pnl>=0?'var(--green)':'var(--red)')+'">'+(pnl>=0?'+':'')+pnl.toFixed(0)+' TL ('+(pnlPct>=0?'+':'')+pnlPct.toFixed(1)+'%)</div>';
      html += '<button onclick="closePosition('+i+')" style="font-size:9px;padding:2px 8px;background:var(--red2);color:var(--red);border:1px solid var(--red);border-radius:3px;cursor:pointer;font-family:inherit;margin-top:2px">KAPAT</button></div>';
      html += '</div>';
    }
  }

  // History
  if (portfolio.history.length > 0) {
    html += '<div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:var(--t3);margin:12px 0 6px">Islem Gecmisi</div>';
    for (var i = portfolio.history.length-1; i >= Math.max(0,portfolio.history.length-10); i--) {
      var h = portfolio.history[i];
      html += '<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:10px;border-bottom:1px solid var(--border)">';
      html += '<span style="color:'+(h.action==='BUY'?'var(--green)':'var(--red)')+'">'+h.action+' '+h.symbol+'</span>';
      html += '<span style="color:var(--t2)">'+h.shares+' @ '+h.price.toFixed(2)+' TL</span></div>';
    }
  }

  el.innerHTML = html;
}


// ========= WATCHLIST & PRICE ALERTS =========
var watchlist = JSON.parse(localStorage.getItem('bist_watchlist') || '[]');

function addToWatchlist(symbol, targetUp, targetDown) {
  var exists = watchlist.find(function(w){return w.symbol === symbol});
  if (exists) { exists.targetUp = targetUp; exists.targetDown = targetDown; }
  else { watchlist.push({symbol:symbol, targetUp:targetUp, targetDown:targetDown, addedAt:Date.now()}); }
  localStorage.setItem('bist_watchlist', JSON.stringify(watchlist));
  renderWatchlist();
}

function removeFromWatchlist(idx) {
  watchlist.splice(idx, 1);
  localStorage.setItem('bist_watchlist', JSON.stringify(watchlist));
  renderWatchlist();
}

function renderWatchlist() {
  var el = document.getElementById('watchlistContent');
  if (!el) return;
  if (watchlist.length === 0) {
    el.innerHTML = '<div style="text-align:center;padding:20px;color:var(--t3);font-size:11px">Watchlist bos. Tekil analizden hisse ekleyin.</div>';
    return;
  }
  var html = '';
  for (var i = 0; i < watchlist.length; i++) {
    var w = watchlist[i];
    html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px;background:var(--bg3);border-radius:5px;margin-bottom:4px">';
    html += '<div><span style="font-weight:700;cursor:pointer;color:var(--t1)" onclick="document.getElementById(\x27symInp\x27).value=\x27'+w.symbol+'\x27;switchTab(\x27analyze\x27);doAnalyze()">'+w.symbol+'</span>';
    if (w.targetUp) html += ' <span style="font-size:9px;color:var(--green)">▲'+w.targetUp.toFixed(2)+'</span>';
    if (w.targetDown) html += ' <span style="font-size:9px;color:var(--red)">▼'+w.targetDown.toFixed(2)+'</span>';
    html += '</div>';
    html += '<button onclick="removeFromWatchlist('+i+')" style="font-size:9px;padding:2px 6px;background:none;color:var(--red);border:1px solid var(--red);border-radius:3px;cursor:pointer;font-family:inherit">X</button>';
    html += '</div>';
  }
  el.innerHTML = html;
}

// Check watchlist alerts
async function checkWatchlistAlerts() {
  if (watchlist.length === 0) return;
  for (var i = 0; i < watchlist.length; i++) {
    var w = watchlist[i];
    try {
      var data = await fetchSingle(w.symbol, '5d', '1d', true);
      if (!data) continue;
      var price = data.prices[data.prices.length-1].close;
      w.lastPrice = price;
      if (w.targetUp && price >= w.targetUp) {
        showNotification(w.symbol + ' hedef fiyata ulasti: ' + price.toFixed(2) + ' TL (hedef: ' + w.targetUp.toFixed(2) + ')');
      }
      if (w.targetDown && price <= w.targetDown) {
        showNotification(w.symbol + ' stop seviyesine dusty: ' + price.toFixed(2) + ' TL (stop: ' + w.targetDown.toFixed(2) + ')');
      }
    } catch(e) {}
  }
  localStorage.setItem('bist_watchlist', JSON.stringify(watchlist));
  renderWatchlist();
}

function showNotification(msg) {
  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification('BIST Alert', {body: msg, icon: 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y="80" font-size="80">📈</text></svg>'});
  }
  // Also show in-app
  var el = document.getElementById('alertBox');
  if (el) {
    el.style.display = 'block';
    el.innerHTML = '<div style="padding:10px;background:var(--yellow2);border:1px solid var(--yellow);border-radius:5px;font-size:11px;color:var(--yellow);margin-bottom:8px">🔔 ' + msg + '</div>' + el.innerHTML;
  }
}

function requestNotificationPermission() {
  if ('Notification' in window) {
    Notification.requestPermission().then(function(p) {
      if (p === 'granted') showNotification('Bildirimler aktif!');
    });
  }
}



// ========= BACKTEST ENGINE =========




// MULTI-STOCK BACKTEST (BIST30)




// ========= INLINE BACKTEST (uses already-fetched data) =========
function runInlineBacktest(strategyName) {
  if (!G_data || !G_data.prices || G_data.prices.length < 25) {
    alert('Once bir hisse analiz edin.');
    return;
  }
  var strategy = strategyName || 'signal';
  var prices = G_data.prices;
  var symbol = G_data.symbol;
  var trades = [];
  var lookback = 20;
  var inTrade = false;
  var tradeEntry = null;

  for (var i = lookback; i < prices.length; i++) {
    var slice = prices.slice(Math.max(0, i - 200), i + 1);
    var ind = calcAll(slice);
    var sig = genSignal(ind, slice);
    var p = prices[i].close;

    if (!inTrade) {
      var buy = false;
      if (strategy === 'signal') buy = sig.score >= 2;
      else if (strategy === 'rsi') buy = ind.lastRSI != null && ind.lastRSI < 30;
      else if (strategy === 'macd') buy = ind.lastMACD != null && ind.lastMACDSig != null && ind.lastMACD > ind.lastMACDSig && (i > lookback && ind.macd.macd[i-1] != null && ind.macd.signal[i-1] != null && ind.macd.macd[i-1] <= ind.macd.signal[i-1]);
      else if (strategy === 'ma') buy = ind.lastMA20 && ind.lastMA50 && ind.lastMA20 > ind.lastMA50 && (i > lookback && ind.ma20[i-1] && ind.ma50[i-1] && ind.ma20[i-1] <= ind.ma50[i-1]);

      if (buy) {
        tradeEntry = {idx:i, price:p, date:prices[i].date, stop:sig.stop, target:sig.t1};
        inTrade = true;
      }
    } else {
      var hitStop = prices[i].low <= tradeEntry.stop;
      var hitTarget = prices[i].high >= tradeEntry.target;
      var days = i - tradeEntry.idx;

      if (hitStop) {
        trades.push({entry:tradeEntry.price, exit:tradeEntry.stop, entryDate:tradeEntry.date, exitDate:prices[i].date, days:days, pnl:(tradeEntry.stop-tradeEntry.price)/tradeEntry.price*100, result:'stop'});
        inTrade = false;
      } else if (hitTarget) {
        trades.push({entry:tradeEntry.price, exit:tradeEntry.target, entryDate:tradeEntry.date, exitDate:prices[i].date, days:days, pnl:(tradeEntry.target-tradeEntry.price)/tradeEntry.price*100, result:'target'});
        inTrade = false;
      } else if (days > 25) {
        trades.push({entry:tradeEntry.price, exit:p, entryDate:tradeEntry.date, exitDate:prices[i].date, days:days, pnl:(p-tradeEntry.price)/tradeEntry.price*100, result:'timeout'});
        inTrade = false;
      }
    }
  }
  if (inTrade) {
    var lp = prices[prices.length-1].close;
    trades.push({entry:tradeEntry.price, exit:lp, entryDate:tradeEntry.date, exitDate:prices[prices.length-1].date, days:prices.length-1-tradeEntry.idx, pnl:(lp-tradeEntry.price)/tradeEntry.price*100, result:'open'});
  }

  showBacktestResults(symbol, strategy, trades, prices.length);
}

function showBacktestResults(symbol, strategy, trades, totalDays) {
  var el = document.getElementById('btInlineResults');
  if (!el) return;
  el.style.display = 'block';

  var closed = trades.filter(function(t){return t.result !== 'open'});
  var wins = closed.filter(function(t){return t.pnl > 0});
  var losses = closed.filter(function(t){return t.pnl <= 0});
  var winRate = closed.length > 0 ? (wins.length / closed.length * 100) : 0;
  var totalRet = closed.reduce(function(a,t){return a + t.pnl}, 0);
  var avgWin = wins.length > 0 ? wins.reduce(function(a,t){return a+t.pnl},0)/wins.length : 0;
  var avgLoss = losses.length > 0 ? losses.reduce(function(a,t){return a+t.pnl},0)/losses.length : 0;
  var pf = avgLoss !== 0 ? Math.abs(avgWin * wins.length / (avgLoss * losses.length || 1)) : 0;
  var expect = closed.length > 0 ? totalRet / closed.length : 0;

  // Equity curve
  var equity = [10000];
  var maxEq = 10000, maxDD = 0;
  for (var i = 0; i < closed.length; i++) {
    var eq = equity[equity.length-1] * (1 + closed[i].pnl/100);
    equity.push(eq);
    if (eq > maxEq) maxEq = eq;
    var dd = (maxEq - eq) / maxEq * 100;
    if (dd > maxDD) maxDD = dd;
  }
  var finalEq = equity[equity.length-1];

  var names = {signal:'Sinyal Motoru', rsi:'RSI<30 Bounce', macd:'MACD Cross', ma:'MA Cross'};
  var wrC = winRate >= 55 ? 'var(--green)' : winRate >= 45 ? 'var(--yellow)' : 'var(--red)';
  var trC = totalRet >= 0 ? 'var(--green)' : 'var(--red)';

  var h = '<div style="font-size:11px;font-weight:700;color:var(--cyan);margin-bottom:10px">⚡ '+symbol+' BACKTEST — '+names[strategy]+' ('+totalDays+' gun)</div>';

  // KPIs in compact grid
  h += '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px">';
  h += '<div style="background:var(--bg0);padding:8px;border-radius:4px;text-align:center"><div style="font-size:7px;text-transform:uppercase;color:var(--t3)">Kazanma</div><div style="font-size:18px;font-weight:700;color:'+wrC+'">%'+winRate.toFixed(0)+'</div><div style="font-size:8px;color:var(--t3)">'+wins.length+'W/'+losses.length+'L</div></div>';
  h += '<div style="background:var(--bg0);padding:8px;border-radius:4px;text-align:center"><div style="font-size:7px;text-transform:uppercase;color:var(--t3)">Toplam</div><div style="font-size:18px;font-weight:700;color:'+trC+'">'+(totalRet>=0?'+':'')+totalRet.toFixed(1)+'%</div></div>';
  h += '<div style="background:var(--bg0);padding:8px;border-radius:4px;text-align:center"><div style="font-size:7px;text-transform:uppercase;color:var(--t3)">10K Sonuc</div><div style="font-size:18px;font-weight:700;color:'+(finalEq>=10000?'var(--green)':'var(--red)')+'">'+finalEq.toFixed(0)+'</div></div>';
  h += '</div>';

  h += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:10px;font-size:9px">';
  h += '<div class="tr-row"><span class="tr-l">Drawdown</span><span class="tr-v r">-'+maxDD.toFixed(1)+'%</span></div>';
  h += '<div class="tr-row"><span class="tr-l">P.Factor</span><span class="tr-v" style="color:'+(pf>=1.5?'var(--green)':'var(--yellow)')+'">'+(pf>10?'>10':pf.toFixed(1))+'</span></div>';
  h += '<div class="tr-row"><span class="tr-l">Ort.Kazanc</span><span class="tr-v g">+'+avgWin.toFixed(1)+'%</span></div>';
  h += '<div class="tr-row"><span class="tr-l">Ort.Kayip</span><span class="tr-v r">'+avgLoss.toFixed(1)+'%</span></div>';
  h += '</div>';

  // Equity mini chart
  if (equity.length > 2) {
    var cw=280,ch=60;
    var minE=Math.min.apply(null,equity),maxE2=Math.max.apply(null,equity);
    var svg='<svg width="100%" viewBox="0 0 '+cw+' '+ch+'" preserveAspectRatio="none" style="display:block;margin-bottom:8px">';
    svg+='<line x1="0" y1="'+(ch*(1-(10000-minE)/(maxE2-minE||1)))+'" x2="'+cw+'" y2="'+(ch*(1-(10000-minE)/(maxE2-minE||1)))+'" stroke="#ffd600" stroke-width="0.5" stroke-dasharray="2,2"/>';
    svg+='<polyline fill="none" stroke="'+(finalEq>=10000?'#00e676':'#ff1744')+'" stroke-width="1.5" points="';
    for(var i=0;i<equity.length;i++){svg+=(i/(equity.length-1)*cw).toFixed(1)+','+(ch-((equity[i]-minE)/(maxE2-minE||1))*(ch-6)-3).toFixed(1)+' ';}
    svg+='"/></svg>';
    h += svg;
  }

  // Verdict
  var vt,vc;
  if(winRate>=55&&pf>=1.5&&expect>0.5){vt='GUCLU — Bu strateji bu hissede calisiyor';vc='var(--green)';}
  else if(winRate>=45&&expect>0){vt='ORTA — Disiplinle marjinal kar mumkun';vc='var(--yellow)';}
  else{vt='ZAYIF — Farkli strateji veya hisse dene';vc='var(--red)';}
  h+='<div style="padding:6px 10px;border-left:3px solid '+vc+';border-radius:4px;font-size:10px;color:'+vc+';font-weight:600;margin-bottom:8px">'+vt+'</div>';

  // Compact trade list
  if(trades.length>0){
    h+='<details style="font-size:9px"><summary style="cursor:pointer;color:var(--t2);margin-bottom:4px">Islem Detaylari ('+trades.length+' islem)</summary>';
    h+='<div style="max-height:150px;overflow-y:auto">';
    for(var i=0;i<trades.length;i++){
      var t=trades[i];var c=t.pnl>=0?'var(--green)':'var(--red)';
      var icon=t.result==='target'?'🎯':t.result==='stop'?'🛑':t.result==='open'?'⏳':t.pnl>=0?'✓':'✕';
      h+='<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border)">';
      h+='<span>'+icon+' '+t.entryDate.toLocaleDateString('tr-TR',{day:'2-digit',month:'short'})+' → '+t.exitDate.toLocaleDateString('tr-TR',{day:'2-digit',month:'short'})+' ('+t.days+'g)</span>';
      h+='<span style="color:'+c+';font-weight:600">'+(t.pnl>=0?'+':'')+t.pnl.toFixed(1)+'%</span></div>';
    }
    h+='</div></details>';
  }

  el.innerHTML = h;
}


</script>
</body>
</html>
