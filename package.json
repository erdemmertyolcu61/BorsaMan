{
  "name": "bist-ai-trading-terminal",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "BIST AI Terminal",
  "description": "BIST AI Trading Terminal - Borsa Istanbul Analiz ve Sinyal Platformu",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ml:export": "python scripts/export_ml_rules.py",
    "lint": "eslint src --ext .js,.jsx --max-warnings 0 || true",
    "postinstall": "electron-builder install-app-deps",
    "electron:dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:prod": "cross-env BUILD_TARGET=electron vite build && electron .",
    "electron:build": "cross-env BUILD_TARGET=electron vite build && electron-builder --win",
    "electron:build:dir": "cross-env BUILD_TARGET=electron vite build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.bist-ai.trading-terminal",
    "productName": "BIST AI Trading Terminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BIST AI Terminal",
      "installerIcon": "public/icons/icon.ico",
      "uninstallerIcon": "public/icons/icon.ico",
      "installerHeaderIcon": "public/icons/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@google/generative-ai": "^0.24.1",
    "app-builder-bin": "^5.0.0-alpha.12",
    "better-sqlite3": "^12.9.0",
    "borsajs": "^0.3.0",
    "dompurify": "^3.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^25.0.1",
    "png-to-ico": "^3.0.1",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.4"
  }
}
