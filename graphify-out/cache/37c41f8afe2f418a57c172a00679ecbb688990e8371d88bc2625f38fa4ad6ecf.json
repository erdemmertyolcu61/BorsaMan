bs", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L268"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L269"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L269"}, {"caller_nid": "analyzetab_analyzetab", "callee": "abs", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L269"}, {"caller_nid": "analyzetab_analyzetab", "callee": "(() => {\n                const bullish = gSig.reasons.filter(r => r.c === 'bullish').length;\n                const bearish = gSig.reasons.filter(r => r.c === 'bearish').length;\n                const total = bullish + bearish || 1;\n                const ratio = bullish / total * 100;\n                return (\n                  <div style={{ marginTop: 10 }}>\n                    <div style={{ fontSize: 8, color: 'var(--t3)', marginBottom: 4 }}>Y\u00fckseli\u015f / D\u00fc\u015f\u00fc\u015f Oran\u0131: {bullish} y\u00fckseli\u015f, {bearish} d\u00fc\u015f\u00fc\u015f</div>\n                    <div style={{ height: 6, background: 'var(--bg0)', borderRadius: 3, overflow: 'hidden', display: 'flex' }}>\n                      <div style={{ width: ratio + '%', background: 'var(--green)', transition: 'width 0.3s' }} />\n                      <div style={{ width: (100 - ratio) + '%', background: 'var(--red)', transition: 'width 0.3s' }} />\n                    </div>\n                  </div>\n                );\n              })", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L273"}, {"caller_nid": "analyzetab_analyzetab", "callee": "includes", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L311"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L320"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L326"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L327"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L327"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L328"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L328"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L329"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L329"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L330"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L331"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L332"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L334"}, {"caller_nid": "analyzetab_analyzetab", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L334"}, {"caller_nid": "analyzetab_analyzetab", "callee": "(() => {\n                const pos = calcPosition(portfolio?.cash || 10000, 2, gSig.entry, gSig.stop);\n                const alreadyOpen = portfolio?.positions?.some(p => p.symbol === gData.symbol && p.status === 'open');\n                const shares = customShares ? parseInt(customShares, 10) : pos.shares;\n                const maxShares = Math.floor((portfolio?.cash || 10000) / gSig.entry);\n                const validShares = shares > 0 && shares <= maxShares;\n                const cost = shares * gSig.entry;\n                const risk = shares * Math.abs(gSig.entry - gSig.stop);\n                return (\n                  <div style={{ marginTop: 10, borderTop: '1px solid var(--border)', paddingTop: 10 }}>\n                    <div style={{ fontSize: 9, color: 'var(--t3)', marginBottom: 6 }}>Kelly \u00d6nerisi: {pos.shares} lot (%2 risk) | Max: {maxShares} lot | Nakit: {(portfolio?.cash || 0).toFixed(0)} TL</div>\n                    <div style={{ display: 'flex', gap: 6, marginBottom: 10 }}>\n                      <button onClick={() => setPositionType('trade')} style={{ flex: 1, padding: 6, fontSize: 10, background: positionType === 'trade' ? 'var(--cyan)' : 'var(--bg3)', color: positionType === 'trade' ? '#000' : 'var(--t2)', border: 'none', borderRadius: 4, fontWeight: positionType === 'trade' ? 700 : 400, cursor: 'pointer' }}>KISA VADE (TRADE)</button>\n                      <button onClick={() => setPositionType('investment')} style={{ flex: 1, padding: 6, fontSize: 10, background: positionType === 'investment' ? 'var(--purple)' : 'var(--bg3)', color: positionType === 'investment' ? '#fff' : 'var(--t2)', border: 'none', borderRadius: 4, fontWeight: positionType === 'investment' ? 700 : 400, cursor: 'pointer' }}>UZUN VADE (YATIRIM)</button>\n                    </div>\n                    <div style={{ display: 'flex', gap: 6, alignItems: 'center', marginBottom: 8 }}>\n                      <input className=\"inp\" type=\"number\" min=\"1\" max={maxShares} value={customShares || pos.shares} onChange={e => setCustomShares(e.target.value)} style={{ width: 80, fontSize: 11, padding: 6, textAlign: 'center' }} />\n                      <span style={{ fontSize: 10, color: 'var(--t2)' }}>lot</span>\n                      <span style={{ fontSize: 10, color: 'var(--t3)', marginLeft: 'auto' }}>Maliyet: <b style={{ color: 'var(--cyan)' }}>{cost.toFixed(0)} TL</b> | Risk: {positionType === 'trade' ? <b style={{ color: 'var(--red)' }}>{risk.toFixed(0)} TL</b> : <span style={{color: 'var(--t2)'}}>Stopsiz (Uzun Vade)</span>}</span>\n                    </div>\n                    {alreadyOpen ? (\n                      <div style={{ fontSize: 10, color: 'var(--yellow)', textAlign: 'center', padding: 6 }}>Bu hisse zaten portf\u00f6yde a\u00e7\u0131k.</div>\n                    ) : addedMsg ? (\n                      <div style={{ fontSize: 10, color: 'var(--green)', textAlign: 'center', padding: 6 }}>{addedMsg}</div>\n                    ) : validShares ? (\n                      <button className=\"btn btn-go\" style={{ width: '100%', fontSize: 11, padding: 8 }} onClick={() => {\n                        const order = { symbol: gData.symbol, price: gSig.entry, stop: gSig.stop, target: gSig.t1, shares, positionType };\n                        setPendingOrder(order);\n                        setIsOrderModalOpen(true);\n                      }}>\n                        {brokerConfig.type === BROKER_TYPES.MIDAS_MANUAL ? '\ud83d\udcf1 MIDAS\\'TA \u0130\u015eLEM YAP' : '+ PORTF\u00d6YE EKLE'} ({shares} lot @ {gSig.entry.toFixed(2)} TL)\n                      </button>\n                    ) : (\n                      <div style={{ fontSize: 10, color: 'var(--red)', textAlign: 'center', padding: 6 }}>\n                        {shares <= 0 ? 'Lot say\u0131s\u0131 ge\u00e7ersiz' : 'Yetersiz nakit (' + (portfolio?.cash || 0).toFixed(0) + ' TL)'}\n                      </div>\n                    )}\n                  </div>\n                );\n              })", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L345"}, {"caller_nid": "analyzetab_analyzetab", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L411"}, {"caller_nid": "analyzetab_analyzetab", "callee": "(() => {\n              const bullish = gSig.reasons.filter(r => r.c === 'bullish');\n              const bearish = gSig.reasons.filter(r => r.c === 'bearish');\n              const neutral = gSig.reasons.filter(r => r.c !== 'bullish' && r.c !== 'bearish');\n              const groups = [\n                { key: 'bullish', label: '\u25b2 Y\u00fckseli\u015f Sinyalleri', items: bullish, color: 'var(--green)', bg: 'var(--green2)' },\n                { key: 'bearish', label: '\u25bc D\u00fc\u015f\u00fc\u015f Sinyalleri', items: bearish, color: 'var(--red)', bg: 'var(--red2)' },\n                { key: 'neutral', label: '\u25c6 N\u00f6tr G\u00f6stergeler', items: neutral, color: 'var(--yellow)', bg: 'var(--yellow2)' },\n              ].filter(g => g.items.length > 0);\n\n              return (\n                <div className=\"fi\" style={{ marginTop: 14 }}>\n                  <div className=\"trade-title\">Gerek\u00e7eler ({gSig.reasons.length})</div>\n                  {groups.map(g => (\n                    <ReasonsGroup key={g.key} label={g.label} items={g.items} color={g.color} bg={g.bg} />\n                  ))}\n                </div>\n              );\n            })", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Analyze\\AnalyzeTab.jsx", "source_location": "L447"}]}