Journal.jsx", "source_location": "L366"}, {"caller_nid": "tradejournal_tradejournal", "callee": "toFixed", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L366"}, {"caller_nid": "tradejournal_tradejournal", "callee": "(() => {\n                  const pts = stats.equityCurve;\n                  const pnls = pts.map(p => p.pnl);\n                  const min = Math.min(0, ...pnls);\n                  const max = Math.max(0, ...pnls);\n                  const range = (max - min) || 1;\n                  const zeroY = ((max - 0) / range) * 100;\n                  const width = pts.length * 10;\n                  return (\n                    <svg viewBox={`0 0 ${width} 80`} style={{ width: '100%', height: '100%' }} preserveAspectRatio=\"none\">\n                      <line x1=\"0\" y1={zeroY * 0.8} x2={width} y2={zeroY * 0.8} stroke=\"rgba(255,255,255,0.15)\" strokeDasharray=\"3,3\" />\n                      <path\n                        d={pts.map((p, i) => {\n                          const x = i * 10 + 5;\n                          const y = ((max - p.pnl) / range) * 76 + 2;\n                          return (i === 0 ? 'M' : 'L') + x + ',' + y;\n                        }).join(' ') + ` L${(pts.length - 1) * 10 + 5},${zeroY * 0.76 + 2} L5,${zeroY * 0.76 + 2} Z`}\n                        fill={stats.totalPnl >= 0 ? 'rgba(0,230,118,0.15)' : 'rgba(255,23,68,0.15)'}\n                      />\n                      <polyline\n                        points={pts.map((p, i) => `${i * 10 + 5},${((max - p.pnl) / range) * 76 + 2}`).join(' ')}\n                        fill=\"none\"\n                        stroke={stats.totalPnl >= 0 ? '#00e676' : '#ff1744'}\n                        strokeWidth=\"1.5\"\n                      />\n                      {pts.map((p, i) => (\n                        <circle\n                          key={i}\n                          cx={i * 10 + 5}\n                          cy={((max - p.pnl) / range) * 76 + 2}\n                          r=\"2\"\n                          fill={p.single >= 0 ? '#00e676' : '#ff1744'}\n                        />\n                      ))}\n                    </svg>\n                  );\n                })", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L370"}, {"caller_nid": "tradejournal_tradejournal", "callee": "keys", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L412"}, {"caller_nid": "tradejournal_tradejournal", "callee": "(() => {\n                  const entries = Object.entries(stats.dailyPnl).sort((a, b) => a[0].localeCompare(b[0])).slice(-20);\n                  const peakAbs = Math.max(...entries.map(([, v]) => Math.abs(v.pnl)), 1);\n                  return entries.map(([date, v]) => {\n                    const h = (Math.abs(v.pnl) / peakAbs) * 50;\n                    const positive = v.pnl >= 0;\n                    return (\n                      <div\n                        key={date}\n                        style={{ flex: 1, display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'flex-end' }}\n                        title={`${date}: ${v.pnl >= 0 ? '+' : ''}${v.pnl.toFixed(0)} TL (${v.count} trade)`}\n                      >\n                        <div style={{\n                          width: '80%', height: h, minHeight: 2, borderRadius: 2,\n                          background: positive ? 'var(--green)' : 'var(--red)', opacity: 0.8,\n                        }} />\n                        <div style={{\n                          fontSize: 6, color: 'var(--t3)', marginTop: 2,\n                          transform: 'rotate(-45deg)', whiteSpace: 'nowrap',\n                        }}>\n                          {date.slice(5)}\n                        </div>\n                      </div>\n                    );\n                  });\n                })", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L416"}, {"caller_nid": "tradejournal_tradejournal", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L476"}, {"caller_nid": "tradejournal_tradejournal", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L504"}, {"caller_nid": "tradejournal_tradejournal", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L524"}, {"caller_nid": "tradejournal_tradejournal", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L562"}, {"caller_nid": "tradejournal_tradejournal", "callee": "filter", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L564"}, {"caller_nid": "tradejournal_tradejournal", "callee": "filter", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L565"}, {"caller_nid": "tradejournal_tradejournal", "callee": "map", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L591"}, {"caller_nid": "tradejournal_tradejournal", "callee": "slice", "source_file": "C:\\Users\\Erdem Mert Yolcu\\Desktop\\bist-terminal-project\\src\\components\\Portfolio\\TradeJournal.jsx", "source_location": "L591"}]}