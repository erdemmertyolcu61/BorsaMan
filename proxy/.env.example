# BIST Proxy Server Configuration

# Server Ports
PORT=3001
WS_PORT=8080

# Update Intervals (milliseconds)
UPDATE_INTERVAL=5000

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60

# Cache TTL (seconds)
CACHE_TTL_STOCKS=300
CACHE_TTL_INDICES=60
CACHE_TTL_LIVE=30

# Yahoo Finance Settings
YAHOO_TIMEOUT=15000
YAHOO_RETRIES=3

# BigPara Settings
BIGPARA_TIMEOUT=10000
BIGPARA_RETRIES=2

# İş Yatırım Settings
ISYATIRIM_TIMEOUT=15000

# Vercel Deployment
# VERCEL_URL=https://your-proxy.vercel.app
